# Host-only shape for /etc/finite/phala-runner.env. Install the live file only
# through scripts/install-phala-canary-credentials; do not copy this template.
#
# Before any authorized installation:
#   owner root:root, mode 0600
#   never source this file into an interactive shell
#   never print, trace, journal, or commit its values
#
# Leave required values empty in this public template so copying it cannot
# accidentally create a production-ready worker.
#
# The Identity Authority loopback URL and operator token are intentionally not
# stored here. Nix supplies the URL, and systemd reads the shared token from
# /etc/finite/identity-operator.env for both Kata and Phala workers.

# A distinct Core keyring credential whose record is named
# `finite-phala-runner-1` and is bound to:
#   worker id:     finite-phala-runner-1
#   class:         phala
#   source host:   finite-lat-1-phala-control-1
# The process-local Runner contract keeps the standard variable name; this
# value must not equal the Kata worker's FC_CORE_RUNNER_API_TOKEN.
FC_CORE_RUNNER_API_TOKEN=

# A Phala Cloud HTTPS API key scoped to the Finite workspace. The typed adapter
# sends it only as X-API-Key to the pinned official API origin.
FC_RUNNER_PHALA_API_KEY=

# Dedicated specialization credential copied on-host from the existing Kata
# Runner secret. It is encrypted into the Runtime environment; it is never a
# Phala or Core control credential.
FC_RUNNER_FINITE_PRIVATE_SPECIALIZATION_WORKER_API_KEY=

# Workspace identity fences, exact Runtime artifact id, public Runtime
# environment, and the systemd-credential path for shared Runtime secrets are
# non-secret facts pinned by the checked-in Nix unit.
