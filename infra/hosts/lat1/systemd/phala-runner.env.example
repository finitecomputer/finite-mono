# Host-only template for /etc/finite/phala-runner.env.
FINITE_IDENTITY_AUTHORITY=https://identity.finite.chat
FINITE_IDENTITY_OPERATOR_TOKEN=replace-with-identity-operator-token
#
# Before any authorized installation:
#   owner root:root, mode 0600
#   never source this file into an interactive shell
#   never print, trace, journal, or commit its values
#
# Leave required values empty in this public template so copying it cannot
# accidentally create a production-ready worker.

# A distinct Core keyring credential whose record is named
# `finite-phala-runner-1` and is bound to:
#   worker id:     finite-phala-runner-1
#   class:         phala
#   source host:   finite-lat-1-phala-control-1
# The process-local Runner contract keeps the standard variable name; this
# value must not equal the Kata worker's FC_CORE_RUNNER_API_TOKEN.
FC_CORE_RUNNER_API_TOKEN=

# A Phala Cloud HTTPS API key scoped to the Finite workspace. The typed adapter
# sends it only as X-API-Key to the pinned official API origin.
FC_RUNNER_PHALA_API_KEY=

# Non-secret identity fence for the Phala workspace this key is allowed to
# represent. The typed startup preflight compares both values with GET
# /auth/me before advertising new creation capacity. Use the immutable
# workspace id plus its expected slug; never infer authority from the key
# merely authenticating successfully. Missing/malformed values are static
# configuration errors; authenticated mismatch later drains new creation.
FC_RUNNER_PHALA_EXPECTED_WORKSPACE_ID=
FC_RUNNER_PHALA_EXPECTED_WORKSPACE_SLUG=

# Exact promoted canonical Runtime artifact already proven by Docker and Kata.
# Use its Core artifact id; do not put a mutable provider image tag here.
FC_RUNNER_RUNTIME_ARTIFACT_ID=

# Optional shared runtime secret transport remains separate and host-only.
# Do not place provider, Core, or recovery-authority credentials in that file.
FC_RUNNER_RUNTIME_SECRET_ENV_FILE=/etc/finite/runtime-secrets.env

# N-1 fallback only. Core's FC_CORE_RUNTIME_ENV_JSON is authoritative for new
# RuntimeSpecs; a present spec never merges this process-global map.
FC_RUNNER_RUNTIME_ENV_JSON={"FINITE_SITES_API":"https://api.finite.chat","FINITE_BRAIN_SERVER_URL":"https://finite.computer","FINITE_BRAIN_PUBLIC_BASE_URL":"https://finite.computer"}
