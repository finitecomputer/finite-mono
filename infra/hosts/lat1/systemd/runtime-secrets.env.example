# Host-only shared runtime provider credentials.
# Install as /etc/finite/runtime-secrets.env, root:root 0600.
# Values are never committed and Runner transports them opaquely.
OPENROUTER_API_KEY=
FAL_KEY=
GOOGLE_PLACES_API_KEY=
FRED_API_KEY=
XAI_API_KEY=
X_API_BEARER_TOKEN=
ELEVENLABS_API_KEY=
FIRECRAWL_API_KEY=
PERPLEXITY_API_KEY=
