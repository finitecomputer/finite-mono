# Host-only template. Install as /etc/finite/runner.env, root:root 0600.
FC_CORE_URL=http://127.0.0.1:4200
FC_CORE_API_TOKEN=replace-with-core-service-token
FC_RUNNER_ID=finite-kata-runner-1
FC_RUNNER_SOURCE_HOST_ID=finite-lat-1

# This worker advertises one adapter class. Each Project selects its class in
# Core; dashboard/product features never mutate this value for an agent.
FC_RUNNER_CLASS=kata
FC_RUNNER_RUNTIME_ARTIFACT_ID=finite-agent-runtime-2026-07-06.1
FC_RUNNER_WORK_ROOT=/var/lib/finite-saas-runner

# Public product endpoints are opaque RuntimeSpec values. Runner transports
# them without learning Sites or Brain behavior.
FC_RUNNER_RUNTIME_ENV_JSON={"FINITE_SITES_API":"https://api.finite.chat","FINITE_BRAIN_SERVER_URL":"https://finite.computer","FINITE_BRAIN_PUBLIC_BASE_URL":"https://finite.computer"}

# Optional host-wide tool/provider credentials resolved only at initial
# launch. Install from runtime-secrets.env.example as root:root 0600. This is
# transitional until Core owns per-Project secret references.
FC_RUNNER_RUNTIME_SECRET_ENV_FILE=/etc/finite/runtime-secrets.env

# Kata/containerd settings. The binaries and Cloud Hypervisor guest assets are
# pinned by flake.lock; no host-global npm or curl-installed runtime is needed.
FC_RUNNER_KATA_NAMESPACE=finite
FC_RUNNER_KATA_OCI_RUNTIME=io.containerd.kata.v2
FC_RUNNER_KATA_NAME_PREFIX=finite-kata
FC_RUNNER_KATA_CONTAINER_PORT=8080
FC_RUNNER_KATA_CPUS=4
FC_RUNNER_KATA_MEMORY=8G
FC_RUNNER_KATA_PULL_POLICY=missing
FC_RUNNER_KATA_STOP_TIMEOUT_SECS=30

# Finite Private defaults. Core provisions a distinct runtime-scoped key at
# lease time; no shared inference secret is required here.
FC_RUNNER_FINITE_PRIVATE_BASE_URL=https://kimi-k2-6.finite.containers.tinfoil.dev/v1
FC_RUNNER_FINITE_PRIVATE_MODEL=glm-5-2

# Maintenance/capacity. Draining prevents new creation leases but keeps
# lifecycle operations available for existing runtimes.
FC_RUNNER_DRAIN=false
FC_RUNNER_MAX_SANDBOXES=12
FC_RUNNER_RUNTIME_READY_TIMEOUT_SECS=300
FC_RUNNER_RUNTIME_READY_INTERVAL_MS=2000
FC_RUNNER_LAUNCH_TIMEOUT_SECS=900
FC_RUNNER_COMMAND_TIMEOUT_SECS=30

# Phala is a fast-follow adapter, not required for this rollout. A dedicated
# worker can advertise FC_RUNNER_CLASS=phala with the following host-only
# values when that lane is enabled:
# PHALA_CLOUD_API_KEY=replace-with-phala-api-key
# FC_RUNNER_PHALA_BIN=/run/current-system/sw/bin/phala
# FC_RUNNER_PHALA_INSTANCE_TYPE=tdx.small
# FC_RUNNER_PHALA_DISK_SIZE=40G
# FC_RUNNER_PHALA_KMS=phala
# FC_RUNNER_PHALA_PUBLIC_LOGS=false
# FC_RUNNER_PHALA_PUBLIC_SYSINFO=false
# FC_RUNNER_PHALA_REGION=us-west

# Enclavia remains an explicit single-target evaluation worker:
# FC_RUNNER_CLASS=enclavia
# FC_RUNNER_ENCLAVIA_BIN=/run/current-system/sw/bin/enclavia
# FC_RUNNER_ENCLAVIA_ENCLAVE_ID=replace-with-enclavia-enclave-uuid
# FC_RUNNER_ENCLAVIA_PULL_POLICY=missing
# FC_RUNNER_DOCKER_BIN=docker
