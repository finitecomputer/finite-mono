# Copy to /etc/finite-saas/sites.env (mode 0600, root:finite-sites or 640).
# Operator-created; deploys never write this file.

# API key for the --mailer provider (Resend shown; Postmark uses
# POSTMARK_SERVER_TOKEN instead).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional Identity Authority URL. When set, finitesitesd resolves email grants
# through finite-identity instead of trusting only Sites-local email keys.
FINITE_IDENTITY_AUTHORITY=https://identity.finite.chat
