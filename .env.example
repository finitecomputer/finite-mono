# Optional WorkOS staging authentication for local Devfinity only. Packaged
# Electron builds use the production dashboard and production WorkOS.
# Copy this file to the repository-root .env, chmod it to 600, then ask Paul for the WorkOS staging
# API key and client ID. .env is ignored and must never be committed.
WORKOS_STAGING_API_KEY=
WORKOS_STAGING_CLIENT_ID=

# Non-secret staging organization used by the local operator flow.
WORKOS_STAGING_OPERATOR_ORG_ID=org_01KSB8XME01MP0K9MEB3JN45QC
