# Bind to host-local by default. Use an SSH tunnel or reverse proxy for access.
PORT=127.0.0.1:3002
HOST=0.0.0.0
USE_DB_AUTHENTICATION=false
BULL_AUTH_KEY=replace-with-strong-random-value

# The upstream nuq-postgres image sets pg_cron's database to "postgres".
# Keep POSTGRES_DB=postgres unless you also change the pg_cron setting.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-random-value
POSTGRES_DB=postgres

# Optional AI features.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# MODEL_NAME=
# MODEL_EMBEDDING_NAME=
# OLLAMA_BASE_URL=

# Optional proxy.
# PROXY_SERVER=
# PROXY_USERNAME=
# PROXY_PASSWORD=

# Optional: lets Firecrawl's own /search endpoint use our SearXNG service.
# This is separate from Hermes web_search, which should still be smoked
# directly against SearXNG.
# SEARXNG_ENDPOINT=http://127.0.0.1:8080
# SEARXNG_ENGINES=
# SEARXNG_CATEGORIES=

# Resource tuning.
MAX_CPU=0.8
MAX_RAM=0.8
