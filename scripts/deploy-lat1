#!/usr/bin/env bash
# One-command lat1 deploy: prebuild on lat2, copy/switch lat1, verify by state.
#
# Usage: scripts/deploy-lat1 <exact-40-hex-mono-rev> [runtime rollout options]
#
# This automates STEPS 1-2 of infra/runbooks/deploy-core.md. Two hard-won
# rules are baked in:
#   1. The switch script executes on lat2 AS A FILE, never via ssh stdin —
#      `ssh ... bash -s` loses the script to the inner ssh calls, which slurp
#      the remaining stdin and exit 0 having mutated nothing.
#   2. Success is proven by comparing lat1's /run/current-system to the
#      prebuilt closure path, never by exit codes alone.
set -euo pipefail

LAT1=root@64.34.82.77
LAT2=ubuntu@finite-lat-2

if [[ $# -lt 1 || ! $1 =~ ^[0-9a-f]{40}$ ]]; then
  echo "usage: $0 <exact-40-hex-mono-rev> [runtime rollout options]" >&2
  exit 64
fi
REV="$1"
shift
ROLLOUT_ARGS=("$@")

if [[ ${#ROLLOUT_ARGS[@]} -gt 0 ]]; then
  scripts/rollout-lat1-runtime-artifact --validate-only "${ROLLOUT_ARGS[@]}"
fi

git fetch origin --prune
git merge-base --is-ancestor "$REV" origin/main || {
  echo "refusing: $REV is not on origin/main" >&2
  exit 65
}

echo "==> prebuilding $REV on lat2"
SYSTEM="$(scripts/nix-build-lat2 "$REV")"
[[ "$SYSTEM" =~ ^/nix/store/[0-9a-z]{32}-nixos-system-finite-lat-1-[^/[:space:]]+$ ]] || {
  echo "prebuild returned unexpected path: $SYSTEM" >&2
  exit 65
}
echo "==> SYSTEM=$SYSTEM"

SWITCH_SCRIPT="$(mktemp)"
trap 'rm -f "$SWITCH_SCRIPT"' EXIT
cat > "$SWITCH_SCRIPT" <<SCRIPT
set -euo pipefail
REV='$REV'
SYSTEM='$SYSTEM'
SCRIPT
cat >> "$SWITCH_SCRIPT" <<'SCRIPT'
ROOT="$HOME/.local/state/finite-mono/lat1-closures/$REV"
test -L "$ROOT"
test "$(readlink -f "$ROOT")" = "$SYSTEM"
nix path-info --option builders '' "$SYSTEM" >/dev/null
ssh -n -o BatchMode=yes root@64.34.82.77 true
echo "==> copying closure to lat1"
nix copy --no-check-sigs --option builders '' \
  --to ssh-ng://root@64.34.82.77 "$SYSTEM"

UNIT="finite-nixos-activate-${REV}.service"
ssh -o BatchMode=yes root@64.34.82.77 \
  bash -s -- "$REV" "$SYSTEM" "$UNIT" <<'LAT1'
set -euo pipefail
rev="$1"
system="$2"
unit="$3"
[[ "$rev" =~ ^[0-9a-f]{40}$ ]] || exit 64
[[ "$system" =~ ^/nix/store/[0-9a-z]{32}-nixos-system-finite-lat-1-[^/[:space:]]+$ ]] || exit 64
[[ "$unit" == "finite-nixos-activate-${rev}.service" ]] || exit 64
test "$(readlink -f "$system")" = "$system"
test -x "$system/bin/switch-to-configuration"
nix-store --check-validity "$system" >/dev/null
load_state="$(systemctl show --property=LoadState --value "$unit" 2>/dev/null || true)"
[[ "$load_state" == not-found ]] || {
  echo "refusing to replace existing transient unit $unit ($load_state)" >&2
  exit 73
}
nix-env --option builders '' --profile /nix/var/nix/profiles/system \
  --set "$system"
test "$(readlink -f /nix/var/nix/profiles/system)" = "$system"
systemd-run --quiet --unit="$unit" --property=Type=oneshot \
  --property=RemainAfterExit=yes --no-block \
  "$system/bin/switch-to-configuration" switch
LAT1
echo "==> activation dispatched, polling"

deadline=$((SECONDS + 600))
while true; do
  if ! state="$(ssh -n -o BatchMode=yes -o ConnectTimeout=5 root@64.34.82.77 \
    systemctl show --property=ActiveState --value "$UNIT" 2>/dev/null)"; then
    state=unreachable
  fi
  case "$state" in
    active) break ;;
    activating|inactive|unreachable) ;;
    failed)
      ssh -n -o BatchMode=yes root@64.34.82.77 \
        journalctl --no-pager -n 100 -u "$UNIT" >&2 || true
      exit 1
      ;;
    *) echo "unexpected activation state: $state" >&2; exit 1 ;;
  esac
  (( SECONDS < deadline )) || { echo "activation timed out" >&2; exit 1; }
  sleep 2
done
PROFILE="$(ssh -n -o BatchMode=yes root@64.34.82.77 \
  readlink -f /nix/var/nix/profiles/system)"
ACTUAL="$(ssh -n -o BatchMode=yes root@64.34.82.77 \
  readlink -f /run/current-system)"
test "$PROFILE" = "$SYSTEM"
test "$ACTUAL" = "$SYSTEM"
ssh -n -o BatchMode=yes root@64.34.82.77 systemctl stop "$UNIT"
echo "SWITCHED: $ACTUAL"
SCRIPT

# Deploys are when the Hosted Web Chat + Identity recovery snapshot happens
# (no calendar timer since 2026-07-14): capture pre-upgrade state while a
# service blip is expected.
echo "==> taking pre-deploy recovery snapshot on lat1"
ssh -n -o BatchMode=yes "$LAT1" \
  'systemctl start finite-hosted-web-chat-snapshot.service && readlink /data/recovery-snapshots/hosted-web-chat/latest'

REMOTE_SCRIPT="/tmp/lat1-switch-${REV}.sh"
echo "==> staging switch script on lat2"
scp -q -o BatchMode=yes "$SWITCH_SCRIPT" "$LAT2:$REMOTE_SCRIPT"
ssh -A -o BatchMode=yes "$LAT2" "bash $REMOTE_SCRIPT && rm -f $REMOTE_SCRIPT"

echo "==> verifying lat1 state from here"
ACTUAL="$(ssh -n -o BatchMode=yes "$LAT1" readlink -f /run/current-system)"
if [[ "$ACTUAL" != "$SYSTEM" ]]; then
  echo "VERIFY FAILED: /run/current-system=$ACTUAL expected $SYSTEM" >&2
  exit 1
fi
ssh -n -o BatchMode=yes "$LAT1" \
  'systemctl is-active finite-saas-core podman-finite-saas-dashboard >/dev/null'
DIGEST="$(ssh -n -o BatchMode=yes "$LAT1" \
  "podman inspect finite-saas-dashboard --format '{{.ImageDigest}}'")"
curl -fsS -o /dev/null https://finite.computer/
echo "==> DEPLOYED rev=$REV"
echo "    system=$SYSTEM"
echo "    dashboard image digest=$DIGEST"

if [[ ${#ROLLOUT_ARGS[@]} -gt 0 ]]; then
  scripts/rollout-lat1-runtime-artifact "${ROLLOUT_ARGS[@]}"
fi
