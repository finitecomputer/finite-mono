#!/usr/bin/env bash
set -euo pipefail

declare -a sensitive_files=()

cleanup_sensitive_files() {
  if (( ${#sensitive_files[@]} > 0 )); then
    rm -f -- "${sensitive_files[@]}"
  fi
}

track_sensitive_file() {
  sensitive_files+=("$1")
}

trap cleanup_sensitive_files EXIT

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 127
  fi
}

check_http() {
  local name="$1"
  local url="$2"
  local expected="$3"
  local body
  body="$(curl -fsS "$url")"
  if [[ "$body" != *"$expected"* ]]; then
    echo "$name smoke failed: $url did not contain '$expected'" >&2
    echo "$body" >&2
    exit 1
  fi
  echo "$name ok: $url"
}

check_tcp() {
  local name="$1"
  local host="$2"
  local port="$3"
  if ! bash -c "exec 3<>/dev/tcp/$host/$port"; then
    echo "$name smoke failed: tcp $host:$port did not accept a connection" >&2
    exit 1
  fi
  echo "$name ok: tcp $host:$port"
}

curl_bearer_file() {
  local token_file="$1"
  shift
  local config_file="${DEVFINITY_STATE_DIR:?}/curl-auth-$$-$RANDOM.conf"
  track_sensitive_file "$config_file"
  umask 077
  printf 'header = "authorization: Bearer %s"\n' "$(tr -d '\n' <"$token_file")" >"$config_file"
  local status=0
  curl -fsS --config "$config_file" "$@" || status=$?
  if (( status != 0 )); then
    rm -f "$config_file"
    return "$status"
  fi
  rm -f "$config_file"
}

check_dashboard_agent_creation() {
  local run_id
  local display_name
  local issue_json
  local launch_code_file
  local idempotency_key
  local response_headers
  local response_body
  local me_json

  run_id="${DEVFINITY_SMOKE_RUN_ID:-$(date +%s)-$$}"
  display_name="Devfinity Smoke Agent $run_id"
  idempotency_key="devfinity-smoke-$run_id"
  response_headers="${DEVFINITY_STATE_DIR:?}/dashboard-create-agent.headers"
  response_body="${DEVFINITY_STATE_DIR:?}/dashboard-create-agent.html"
  me_json="${DEVFINITY_STATE_DIR:?}/core-me-after-dashboard-create.json"
  issue_json="${DEVFINITY_STATE_DIR:?}/issued-launch-code.json"
  launch_code_file="${DEVFINITY_STATE_DIR:?}/issued-launch-code.txt"
  track_sensitive_file "$issue_json"
  track_sensitive_file "$launch_code_file"

  umask 077
  curl_bearer_file "${DEVFINITY_STATE_DIR:?}/workos-fixture/operator.jwt" \
    -H 'content-type: application/json' \
    --data '{"name":"Devfinity services smoke","codeCount":1,"expiresInHours":24}' \
    "$core_url/api/core/v1/admin/launch-code-batches" >"$issue_json"
  node - "$issue_json" "$launch_code_file" <<'JS'
const fs = require("node:fs");
const [issuePath, codePath] = process.argv.slice(2);
const code = JSON.parse(fs.readFileSync(issuePath, "utf8"))?.codes?.[0]?.code;
if (typeof code !== "string" || !code) throw new Error("Core did not return one Launch Code");
fs.writeFileSync(codePath, code, { mode: 0o600 });
JS
  rm -f "$issue_json"

  curl -fsS \
    -D "$response_headers" \
    -o "$response_body" \
    -X POST \
    --data-urlencode "displayName=$display_name" \
    --data-urlencode "access=launch-code" \
    --data-urlencode "launchCode@$launch_code_file" \
    --data-urlencode "idempotencyKey=$idempotency_key" \
    "$dashboard_url/agent-creation-requests"

  if tr -d '\r' <"$response_headers" | grep -Eiq '^location: .*agentCreationError='; then
    echo "dashboard agent creation redirected with an error" >&2
    tr -d '\r' <"$response_headers" | grep -Ei '^location:' >&2 || true
    exit 1
  fi

  rm -f "$launch_code_file"

  curl_bearer_file "${DEVFINITY_STATE_DIR:?}/workos-fixture/dashboard-customer.jwt" \
    "$core_url/api/core/v1/me" \
    >"$me_json"

  node - "$me_json" "$display_name" <<'JS'
const fs = require("node:fs");

const [mePath, displayName] = process.argv.slice(2);
const me = JSON.parse(fs.readFileSync(mePath, "utf8"));
const requests = Array.isArray(me.agent_creation_requests) ? me.agent_creation_requests : [];
const projects = Array.isArray(me.projects) ? me.projects : [];
const request = requests.find((candidate) =>
  candidate.display_name === displayName &&
  (candidate.status === "requested" || candidate.status === "launching")
);

if (!request) {
  throw new Error(`Core did not report a pending dashboard-created agent request for ${displayName}`);
}

const project = projects.find((candidate) => candidate.project?.id === request.project_id);
if (!project) {
  throw new Error(`Core reported request ${request.id} without its project ${request.project_id}`);
}

console.log(`dashboard->core ok: request ${request.id} created project ${request.project_id}`);
JS
}

need bash
need curl
need node

if [[ "${DEVFINITY_PROFILE:-}" != "services-only" ]]; then
  echo "devfinity service smoke requires the explicit services-only profile" >&2
  exit 64
fi

core_url="${FC_CORE_URL:-http://127.0.0.1:14200}"
chat_url="${FINITECHAT_SERVER_URL:-http://127.0.0.1:18787}"
hosted_device_url="${FC_HOSTED_WEB_DEVICE_URL:-http://127.0.0.1:38918}"
sites_url="${FINITE_SITES_API:-http://127.0.0.1:18789}"
brain_url="${FINITE_BRAIN_SERVER_URL:-http://127.0.0.1:18790}"
dashboard_url="${FC_DASHBOARD_URL:-http://127.0.0.1:13002/dashboard}"
postgres_port="${DEVFINITY_POSTGRES_PORT:-15432}"

check_tcp "postgres" "127.0.0.1" "$postgres_port"
check_http "core" "$core_url/healthz" '"ok":true'
check_http "finitechat" "$chat_url/health" '"status":"ok"'
check_http "hosted-web-device" "$hosted_device_url/healthz" '"status":"ok"'
check_http "finitesites" "$sites_url/api/v1/healthz" '"ok":true'
check_http "finitebrain" "$brain_url/health" '"status":"ok"'
check_http "dashboard" "$dashboard_url" '<html'
check_dashboard_agent_creation

echo "devfinity smoke passed"
