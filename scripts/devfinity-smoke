#!/usr/bin/env bash
set -euo pipefail

declare -a sensitive_files=()
declare -a sensitive_dirs=()

cleanup_sensitive_files() {
  if (( ${#sensitive_files[@]} > 0 )); then
    rm -f -- "${sensitive_files[@]}"
  fi
  if (( ${#sensitive_dirs[@]} > 0 )); then
    rm -rf -- "${sensitive_dirs[@]}"
  fi
}

track_sensitive_file() {
  sensitive_files+=("$1")
}

track_sensitive_dir() {
  sensitive_dirs+=("$1")
}

trap cleanup_sensitive_files EXIT

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 127
  fi
}

check_http() {
  local name="$1"
  local url="$2"
  local expected="$3"
  local body
  body="$(curl -fsS "$url")"
  if [[ "$body" != *"$expected"* ]]; then
    echo "$name smoke failed: $url did not contain '$expected'" >&2
    echo "$body" >&2
    exit 1
  fi
  echo "$name ok: $url"
}

check_tcp() {
  local name="$1"
  local host="$2"
  local port="$3"
  if ! bash -c "exec 3<>/dev/tcp/$host/$port"; then
    echo "$name smoke failed: tcp $host:$port did not accept a connection" >&2
    exit 1
  fi
  echo "$name ok: tcp $host:$port"
}

curl_bearer_file() {
  local token_file="$1"
  shift
  local config_file="${DEVFINITY_STATE_DIR:?}/curl-auth-$$-$RANDOM.conf"
  track_sensitive_file "$config_file"
  umask 077
  printf 'header = "authorization: Bearer %s"\n' "$(tr -d '\n' <"$token_file")" >"$config_file"
  local status=0
  curl -fsS --config "$config_file" "$@" || status=$?
  if (( status != 0 )); then
    rm -f "$config_file"
    return "$status"
  fi
  rm -f "$config_file"
}

check_dashboard_agent_creation() {
  local run_id
  local display_name
  local issue_json
  local launch_code_file
  local idempotency_key
  local response_headers
  local response_body
  local me_json

  run_id="${DEVFINITY_SMOKE_RUN_ID:-$(date +%s)-$$}"
  display_name="Devfinity Smoke Agent $run_id"
  idempotency_key="devfinity-smoke-$run_id"
  response_headers="${DEVFINITY_STATE_DIR:?}/dashboard-create-agent.headers"
  response_body="${DEVFINITY_STATE_DIR:?}/dashboard-create-agent.html"
  me_json="${DEVFINITY_STATE_DIR:?}/core-me-after-dashboard-create.json"
  issue_json="${DEVFINITY_STATE_DIR:?}/issued-launch-code.json"
  launch_code_file="${DEVFINITY_STATE_DIR:?}/issued-launch-code.txt"
  track_sensitive_file "$issue_json"
  track_sensitive_file "$launch_code_file"

  umask 077
  curl_bearer_file "${DEVFINITY_STATE_DIR:?}/workos-fixture/operator.jwt" \
    -H 'content-type: application/json' \
    --data '{"name":"Devfinity services smoke","codeCount":1,"expiresInHours":24}' \
    "$core_url/api/core/v1/admin/launch-code-batches" >"$issue_json"
  node - "$issue_json" "$launch_code_file" <<'JS'
const fs = require("node:fs");
const [issuePath, codePath] = process.argv.slice(2);
const code = JSON.parse(fs.readFileSync(issuePath, "utf8"))?.codes?.[0]?.code;
if (typeof code !== "string" || !code) throw new Error("Core did not return one Launch Code");
fs.writeFileSync(codePath, code, { mode: 0o600 });
JS
  rm -f "$issue_json"

  curl -fsS \
    -D "$response_headers" \
    -o "$response_body" \
    -X POST \
    --data-urlencode "displayName=$display_name" \
    --data-urlencode "access=launch-code" \
    --data-urlencode "launchCode@$launch_code_file" \
    --data-urlencode "idempotencyKey=$idempotency_key" \
    "$dashboard_url/agent-creation-requests"

  if tr -d '\r' <"$response_headers" | grep -Eiq '^location: .*agentCreationError='; then
    echo "dashboard agent creation redirected with an error" >&2
    tr -d '\r' <"$response_headers" | grep -Ei '^location:' >&2 || true
    exit 1
  fi

  rm -f "$launch_code_file"

  curl_bearer_file "${DEVFINITY_STATE_DIR:?}/workos-fixture/dashboard-customer.jwt" \
    "$core_url/api/core/v1/me" \
    >"$me_json"

  node - "$me_json" "$display_name" <<'JS'
const fs = require("node:fs");

const [mePath, displayName] = process.argv.slice(2);
const me = JSON.parse(fs.readFileSync(mePath, "utf8"));
const requests = Array.isArray(me.agent_creation_requests) ? me.agent_creation_requests : [];
const projects = Array.isArray(me.projects) ? me.projects : [];
const request = requests.find((candidate) =>
  candidate.display_name === displayName &&
  (candidate.status === "requested" || candidate.status === "launching")
);

if (!request) {
  throw new Error(`Core did not report a pending dashboard-created agent request for ${displayName}`);
}

const project = projects.find((candidate) => candidate.project?.id === request.project_id);
if (!project) {
  throw new Error(`Core reported request ${request.id} without its project ${request.project_id}`);
}

console.log(`dashboard->core ok: request ${request.id} created project ${request.project_id}`);
JS
}

check_native_requesting_user_site() {
  local run_id
  local slug
  local marker
  local smoke_root
  local agent_home
  local agent_finite_home
  local fsite_bin
  local project_dir
  local hosted_config
  local sites_config
  local user_state_json
  local requesting_user_id
  local init_json
  local init_fields
  local output_id
  local output_url
  local git_remote
  local proof_request_json
  local proof_json
  local exchange_json
  local exchange_response_json
  local redeem_url
  local redemption_headers
  local viewer_cookie
  local status
  local body
  local revoke_json

  run_id="${DEVFINITY_SMOKE_RUN_ID:-$(date +%s)-$$}"
  slug="devfinity-private-${run_id}"
  marker="Devfinity private Sites ${run_id}"
  smoke_root="${DEVFINITY_STATE_DIR:?}/sites-native-requester-${run_id}"
  agent_home="$smoke_root/home"
  agent_finite_home="$smoke_root/finite-home"
  fsite_bin="$(pwd)/target/debug/fsite"
  project_dir="$smoke_root/project"
  hosted_config="$smoke_root/hosted-device.curl"
  sites_config="$smoke_root/sites-service.curl"
  user_state_json="$smoke_root/user-state.json"
  init_json="$smoke_root/init.json"
  proof_request_json="$smoke_root/proof-request.json"
  proof_json="$smoke_root/proof.json"
  exchange_json="$smoke_root/exchange.json"
  exchange_response_json="$smoke_root/exchange-response.json"
  redemption_headers="$smoke_root/redemption.headers"
  revoke_json="$smoke_root/revoke.json"
  track_sensitive_dir "$smoke_root"
  umask 077
  mkdir -p "$agent_home" "$agent_finite_home" "$project_dir/site"

  printf 'header = "authorization: Bearer %s"\nheader = "x-finite-workos-user-id: %s"\n' \
    "${FINITECHAT_HOSTED_API_TOKEN:?}" \
    "${FC_DASHBOARD_DEV_WORKOS_USER_ID:?}" \
    >"$hosted_config"
  printf 'header = "authorization: Bearer %s"\n' \
    "${FINITE_SITES_VIEWER_SESSION_TOKEN:?}" \
    >"$sites_config"

  curl -fsS --config "$hosted_config" \
    "$hosted_device_url/v1/app/state" >"$user_state_json"
  requesting_user_id="$(node - "$user_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const accountId = String(state.identity?.account_id || "");
if (!/^[0-9a-f]{64}$/u.test(accountId)) {
  throw new Error("Hosted Device did not expose a Native Principal account id");
}
process.stdout.write(accountId);
JS
)"

  printf '%s\n' \
    '[project]' \
    "slug = \"$slug\"" \
    '' \
    '[outputs.site]' \
    'kind = "site"' \
    "site_name = \"$slug\"" \
    'branch = "main"' \
    'path = "site"' \
    'spa = false' >"$project_dir/finite.toml"
  printf '<h1>%s</h1>\n' "$marker" >"$project_dir/site/index.html"

  cargo build -q -p fsite-cli
  env \
    HOME="$agent_home" \
    FINITE_HOME="$agent_finite_home" \
    FINITE_SITES_API="$sites_url" \
    GIT_CONFIG_GLOBAL="$agent_home/gitconfig" \
    "$fsite_bin" auth register --output json >/dev/null
  (
    cd "$project_dir"
    env \
      HOME="$agent_home" \
      FINITE_HOME="$agent_finite_home" \
      FINITE_SITES_API="$sites_url" \
      GIT_CONFIG_GLOBAL="$agent_home/gitconfig" \
      "$fsite_bin" project init \
        --config finite.toml \
        --requesting-user-npub "$requesting_user_id" \
        --dry-run \
        --output json >/dev/null
    env \
      HOME="$agent_home" \
      FINITE_HOME="$agent_finite_home" \
      FINITE_SITES_API="$sites_url" \
      GIT_CONFIG_GLOBAL="$agent_home/gitconfig" \
      "$fsite_bin" project init \
        --config finite.toml \
        --requesting-user-npub "$requesting_user_id" \
        --output json >"$init_json"
  )
  init_fields="$(node - "$init_json" "$slug" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const output = response.outputs?.[0];
if (
  response.slug !== process.argv[3] ||
  !response.requesting_user_npub?.startsWith("npub1") ||
  !output?.requesting_user_shared ||
  output.visibility !== "private"
) {
  throw new Error(`Project Init did not create a private requesting-user Share: ${JSON.stringify(response)}`);
}
process.stdout.write([output.output_id, output.output_url, response.git_remote_url].join("\t"));
JS
)"
  IFS=$'\t' read -r output_id output_url git_remote <<<"$init_fields"
  echo "Sites smoke Project and requesting-user Share initialized"

  env \
    HOME="$agent_home" \
    FINITE_HOME="$agent_finite_home" \
    FINITE_SITES_API="$sites_url" \
    GIT_CONFIG_GLOBAL="$agent_home/gitconfig" \
    "$fsite_bin" auth git "$slug" --store --output json >/dev/null
  (
    cd "$project_dir"
    export GIT_CONFIG_GLOBAL="$agent_home/gitconfig"
    git init -q -b main
    git config user.name "Devfinity Sites Smoke"
    git config user.email "devfinity-sites-smoke@finite.invalid"
    git add finite.toml site
    git commit -q -m "Publish private requesting-user smoke site"
    git remote add finite "$git_remote"
    git push -q finite main
  )
  echo "Sites smoke private Output published"

  local started
  started="$(date +%s)"
  while true; do
    status="$(curl -sS --max-time 5 -o /dev/null -w '%{http_code}' "$output_url" || true)"
    if [[ "$status" == "401" ]]; then
      break
    fi
    if (( "$(date +%s)" - started >= 60 )); then
      echo "Sites smoke Output did not publish within 60s; last status $status" >&2
      return 1
    fi
    sleep 1
  done

  node - "$output_url" >"$proof_request_json" <<'JS'
const { randomUUID } = require("node:crypto");
const output = new URL(process.argv[2]);
process.stdout.write(JSON.stringify({
  version: "finite-sites-identity-provider-v1",
  operation: "authorizeViewerSession",
  input: {
    url: `${output.origin}/_finite/auth/native-session`,
    returnTo: "/",
    client: "devfinity-services-smoke",
    nonce: randomUUID(),
  },
}));
JS
  echo "Sites smoke requesting bounded proof from Hosted Device"
  curl -fsS --config "$hosted_config" \
    -H 'content-type: application/json' \
    -H "x-finite-sites-public-origin: $(node -e 'process.stdout.write(new URL(process.argv[1]).origin)' "$output_url")" \
    --data-binary "@$proof_request_json" \
    "$hosted_device_url/v1/sites/identity-provider" >"$proof_json"
  node - "$proof_json" "$output_url" >"$exchange_json" <<'JS'
const fs = require("node:fs");
const proof = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (typeof proof.authorization_header !== "string" || typeof proof.body_json !== "string") {
  throw new Error("Hosted Device did not return the bounded Sites proof");
}
process.stdout.write(JSON.stringify({
  output_url: new URL(process.argv[3]).origin + "/",
  authorization: proof.authorization_header,
  signed_body: proof.body_json,
}));
JS
  echo "Sites smoke exchanging bounded proof for Viewer Session"
  curl -fsS --config "$sites_config" \
    -H 'content-type: application/json' \
    --data-binary "@$exchange_json" \
    "$sites_url/internal/v1/native-viewer-sessions" >"$exchange_response_json"
  redeem_url="$(node - "$exchange_response_json" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const redeem = new URL(String(response.redeem_url || ""));
if (!/^[0-9a-f]{64}$/u.test(redeem.searchParams.get("native_token") || "")) {
  throw new Error("Sites did not return a native redemption URL");
}
process.stdout.write(redeem.toString());
JS
)"
  status="$(curl -sS --max-time 15 -D "$redemption_headers" -o /dev/null -w '%{http_code}' "$redeem_url")"
  if [[ "$status" != "303" ]]; then
    echo "Sites smoke redemption returned HTTP $status instead of 303" >&2
    return 1
  fi
  viewer_cookie="$(node - "$redemption_headers" <<'JS'
const fs = require("node:fs");
const headers = fs.readFileSync(process.argv[2], "utf8").split(/\r?\n/u);
const setCookie = headers.find((line) => /^set-cookie:\s*finite_site_auth=/iu.test(line));
if (!setCookie) {
  throw new Error("Sites redemption did not set the host-scoped Viewer Cookie");
}
process.stdout.write(setCookie.replace(/^set-cookie:\s*/iu, "").split(";", 1)[0]);
JS
)"
  echo "Sites smoke Viewer Session redeemed"
  body="$(curl -fsS --max-time 15 -H "Cookie: $viewer_cookie" "$output_url")"
  if [[ "$body" != *"$marker"* ]]; then
    echo "Sites smoke Viewer Cookie did not open the private Output" >&2
    return 1
  fi

  env \
    HOME="$agent_home" \
    FINITE_HOME="$agent_finite_home" \
    FINITE_SITES_API="$sites_url" \
    GIT_CONFIG_GLOBAL="$agent_home/gitconfig" \
    "$fsite_bin" project share "$slug" "$output_id" \
      --remove-npub "$requesting_user_id" \
      --output json >"$revoke_json"
  status="$(curl -sS --max-time 15 -o /dev/null -H "Cookie: $viewer_cookie" -w '%{http_code}' "$output_url")"
  if [[ "$status" != "401" ]]; then
    echo "Revoked Sites smoke Viewer Cookie returned HTTP $status instead of 401" >&2
    return 1
  fi
  echo "agent -> requesting user native Sites view and revocation ok: $output_url"
}

need bash
need curl
need node

if [[ "${DEVFINITY_PROFILE:-}" != "services-only" ]]; then
  echo "devfinity service smoke requires the explicit services-only profile" >&2
  exit 64
fi

core_url="${FC_CORE_URL:-http://127.0.0.1:14200}"
chat_url="${FINITECHAT_SERVER_URL:-http://127.0.0.1:18787}"
hosted_device_url="${FC_HOSTED_WEB_DEVICE_URL:-http://127.0.0.1:38918}"
sites_url="${FINITE_SITES_API:-http://127.0.0.1:18789}"
dashboard_url="${FC_DASHBOARD_URL:-http://127.0.0.1:13002/dashboard}"
postgres_port="${DEVFINITY_POSTGRES_PORT:-15432}"

check_tcp "postgres" "127.0.0.1" "$postgres_port"
check_http "core" "$core_url/healthz" '"ok":true'
check_http "finitechat" "$chat_url/health" '"status":"ok"'
check_http "hosted-web-device" "$hosted_device_url/healthz" '"status":"ok"'
check_http "finitesites" "$sites_url/api/v1/healthz" '"ok":true'
check_http "dashboard" "$dashboard_url" '<html'
check_native_requesting_user_site
check_dashboard_agent_creation

echo "devfinity smoke passed"
