#!/usr/bin/env bash
set -euo pipefail

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 127
  fi
}

check_http() {
  local name="$1"
  local url="$2"
  local expected="$3"
  local body
  body="$(curl -fsS "$url")"
  if [[ "$body" != *"$expected"* ]]; then
    echo "$name smoke failed: $url did not contain '$expected'" >&2
    echo "$body" >&2
    exit 1
  fi
  echo "$name ok: $url"
}

check_tcp() {
  local name="$1"
  local host="$2"
  local port="$3"
  if ! bash -c "exec 3<>/dev/tcp/$host/$port"; then
    echo "$name smoke failed: tcp $host:$port did not accept a connection" >&2
    exit 1
  fi
  echo "$name ok: tcp $host:$port"
}

need bash
need curl

core_url="${FC_CORE_URL:-http://127.0.0.1:14200}"
chat_url="${FINITECHAT_SERVER_URL:-http://127.0.0.1:18787}"
sites_url="${FINITE_SITES_API:-http://127.0.0.1:18789}"
postgres_port="${DEVFINITY_POSTGRES_PORT:-15432}"

check_tcp "postgres" "127.0.0.1" "$postgres_port"
check_http "core" "$core_url/healthz" '"ok":true'
check_http "finitechat" "$chat_url/health" '"status":"ok"'
check_http "finitesites" "$sites_url/api/v1/healthz" '"ok":true'

echo "devfinity backend smoke passed"
