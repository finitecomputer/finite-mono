#!/usr/bin/env bash
# Install the shared Identity Authority operator credential without returning
# its value to the operator shell or placing it in this public repository.
set -euo pipefail

target="${1:-root@64.34.82.77}"

if [[ $# -gt 1 ]]; then
  printf 'usage: %s [root@finite-lat-1]\n' "$0" >&2
  exit 64
fi

remote_hostname="$(ssh -n -o BatchMode=yes "$target" hostname)"
if [[ "$remote_hostname" != "finite-lat-1" ]]; then
  printf 'refusing: %s reports hostname %s, expected finite-lat-1\n' \
    "$target" "$remote_hostname" >&2
  exit 65
fi

ssh -o BatchMode=yes "$target" 'bash -s' <<'REMOTE'
set -euo pipefail
test "$(hostname)" = finite-lat-1

sites_environment=/etc/finite-saas/sites.env
operator_environment=/etc/finite/identity-operator.env

test -f "$sites_environment"
test "$(stat -c %U:%G "$sites_environment")" = root:root
case "$(stat -c %a "$sites_environment")" in
  600|640) ;;
  *)
    echo "refusing: $sites_environment must be mode 0600 or 0640" >&2
    exit 65
    ;;
esac
grep -Eq '^RESEND_API_KEY=.+$' "$sites_environment"

if test -e "$operator_environment"; then
  test -f "$operator_environment"
  test "$(stat -c %U:%G "$operator_environment")" = root:root
  test "$(stat -c %a "$operator_environment")" = 600
  test "$(sed -n 's/^FINITE_IDENTITY_OPERATOR_TOKEN=\\([0-9a-f]\\{64\\}\\)$/\\1/p' "$operator_environment" | wc -l)" = 1
  test "$(sed -n '/^[[:space:]]*#/d; /^[[:space:]]*$/d; p' "$operator_environment" | wc -l)" = 1
  echo "Identity Authority operator credential already installed and valid"
  exit 0
fi

command -v openssl >/dev/null
install -d -m 0755 -o root -g root /etc/finite
temporary="$(mktemp /etc/finite/.identity-operator.env.XXXXXX)"
cleanup() {
  rm -f "$temporary"
}
trap cleanup EXIT
umask 077
token="$(openssl rand -hex 32)"
printf 'FINITE_IDENTITY_OPERATOR_TOKEN=%s\n' "$token" > "$temporary"
unset token
chown root:root "$temporary"
chmod 0600 "$temporary"
mv -n "$temporary" "$operator_environment"
trap - EXIT

test "$(stat -c %U:%G "$operator_environment")" = root:root
test "$(stat -c %a "$operator_environment")" = 600
test "$(sed -n 's/^FINITE_IDENTITY_OPERATOR_TOKEN=\\([0-9a-f]\\{64\\}\\)$/\\1/p' "$operator_environment" | wc -l)" = 1
echo "Installed $operator_environment (root:root 0600; value not displayed)"
REMOTE
