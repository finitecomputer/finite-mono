#!/usr/bin/env bash
set -euo pipefail

builder="ubuntu@finite-lat-2"
system_target="nixosConfigurations.finite-lat-1.config.system.build.toplevel"
disko_target="nixosConfigurations.finite-lat-1.config.system.build.diskoScript"

if [[ $# -ne 1 || ! $1 =~ ^[0-9a-f]{40}$ ]]; then
  echo "usage: $0 <exact-40-hex-mono-rev>" >&2
  exit 64
fi
rev="$1"

# The Mac runs no Nix command at all: it cannot inherit /etc/nix/machines or a
# personal builders setting. Evaluation and realization both happen on lat2,
# with remote builders explicitly disabled. Per-revision system and disko
# out-links are GC roots and are the handoff points used by the runbooks.
system_path="$(ssh -o BatchMode=yes "$builder" \
  bash -s -- "$rev" "$system_target" "$disko_target" <<'REMOTE'
set -euo pipefail

rev="$1"
system_target="$2"
disko_target="$3"

if [[ "$(hostname -s)" != "finite-lat-2" ]]; then
  echo "refusing to build on $(hostname -f): expected finite-lat-2" >&2
  exit 69
fi

current_system="$(nix eval --option builders '' --impure --raw --expr builtins.currentSystem)"
if [[ "$current_system" != "x86_64-linux" ]]; then
  echo "refusing to build on system ${current_system}: expected x86_64-linux" >&2
  exit 69
fi

root_dir="$HOME/.local/state/finite-mono/lat1-closures"
gc_root="${root_dir}/${rev}"
disko_root_dir="$HOME/.local/state/finite-mono/lat1-disko-scripts"
disko_gc_root="${disko_root_dir}/${rev}"
install -d -m 0700 "$root_dir" "$disko_root_dir"
for root in "$gc_root" "$disko_gc_root"; do
  if [[ -e "$root" && ! -L "$root" ]]; then
    echo "refusing to replace non-symlink GC root: ${root}" >&2
    exit 73
  fi
done

out_path="$(nix build \
  --option builders '' \
  --option max-jobs auto \
  --out-link "$gc_root" \
  --print-out-paths \
  "github:finitecomputer/finite-mono/${rev}#${system_target}")"

if [[ ! "$out_path" =~ ^/nix/store/[0-9a-z]{32}-nixos-system-finite-lat-1-[^/[:space:]]+$ ]]; then
  echo "unexpected system output path: ${out_path}" >&2
  exit 70
fi
if [[ ! -x "$out_path/bin/switch-to-configuration" ]]; then
  echo "system output lacks switch-to-configuration: ${out_path}" >&2
  exit 70
fi
if [[ "$(readlink -f "$gc_root")" != "$out_path" ]]; then
  echo "GC root ${gc_root} does not resolve to ${out_path}" >&2
  exit 70
fi

# nixos-anywhere's --store-paths mode also needs the matching disko script.
# Root it under the same immutable revision without adding a second stdout
# value; reinstall runbooks recover it from this documented root.
disko_path="$(nix build \
  --option builders '' \
  --option max-jobs auto \
  --out-link "$disko_gc_root" \
  --print-out-paths \
  "github:finitecomputer/finite-mono/${rev}#${disko_target}")"
if [[ ! "$disko_path" =~ ^/nix/store/[0-9a-z]{32}-[^/[:space:]]+$ ]]; then
  echo "unexpected disko output path: ${disko_path}" >&2
  exit 70
fi
if [[ ! -x "$disko_path" ]]; then
  echo "disko output is not executable: ${disko_path}" >&2
  exit 70
fi
# The disko build output is itself a symlink to its executable. Check the
# out-link's first hop so we prove that Nix rooted the exact output it printed;
# readlink -f would intentionally continue through the output symlink.
if [[ "$(readlink "$disko_gc_root")" != "$disko_path" ]]; then
  echo "GC root ${disko_gc_root} does not point to ${disko_path}" >&2
  exit 70
fi

printf '%s\n' "$out_path"
REMOTE
)"

# Keep stdout machine-readable even if the remote account later gains a login
# banner or another unexpected stdout producer.
if [[ ! "$system_path" =~ ^/nix/store/[0-9a-z]{32}-nixos-system-finite-lat-1-[^/[:space:]]+$ ]]; then
  echo "unexpected remote system output path: ${system_path}" >&2
  exit 70
fi
printf '%s\n' "$system_path"
