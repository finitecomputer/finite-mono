#!/usr/bin/env bash
set -euo pipefail

declare -a sensitive_files=()
updates_pid=""

cleanup_sensitive_files() {
  if [[ -n "$updates_pid" ]]; then
    kill "$updates_pid" >/dev/null 2>&1 || true
    wait "$updates_pid" >/dev/null 2>&1 || true
  fi
  if (( ${#sensitive_files[@]} > 0 )); then
    rm -f -- "${sensitive_files[@]}"
  fi
}

track_sensitive_file() {
  sensitive_files+=("$1")
}

trap cleanup_sensitive_files EXIT

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 127
  fi
}

wait_http() {
  local name="$1"
  local url="$2"
  local timeout_secs="${3:-120}"
  local started
  started="$(date +%s)"
  until curl -fsS --max-time 3 "$url" >/dev/null 2>&1; do
    if (( "$(date +%s)" - started >= timeout_secs )); then
      echo "$name did not become ready at $url within ${timeout_secs}s" >&2
      return 1
    fi
    sleep 1
  done
}

read_core_me() {
  curl_customer "$core_url/api/core/v1/me" >"$me_json"
}

curl_customer() {
  local config_file="$state_dir/saas-smoke-curl-auth-$$-$RANDOM.conf"
  track_sensitive_file "$config_file"
  umask 077
  printf 'header = "authorization: Bearer %s"\n' \
    "$(tr -d '\n' <"$state_dir/workos-fixture/dashboard-customer.jwt")" >"$config_file"
  local status=0
  curl -fsS --config "$config_file" "$@" || status=$?
  if (( status != 0 )); then
    rm -f "$config_file"
    return "$status"
  fi
  rm -f "$config_file"
}

runtime_fields() {
  node - "$me_json" <<'JS'
const fs = require("node:fs");
const me = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const visible = (me.projects || []).find((entry) => entry.runtime);
if (!visible) process.exit(1);
const project = visible.project;
const runtime = visible.runtime;
const contact = new URL(runtime.contact_endpoint);
contact.pathname = contact.pathname.replace(/\/contact\/?$/, "");
process.stdout.write([
  project.id,
  runtime.id,
  contact.toString().replace(/\/$/, ""),
].join("\t"));
JS
}

runtime_container_id() {
  container list --format json | node -e '
    const projectId = process.argv[1];
    let body = "";
    process.stdin.on("data", (chunk) => body += chunk);
    process.stdin.on("end", () => {
      const containers = JSON.parse(body);
      const runtime = containers.find((entry) =>
        entry?.configuration?.labels?.["computer.finite.v2.project_id"] === projectId
      );
      if (!runtime?.configuration?.id) process.exit(1);
      process.stdout.write(runtime.configuration.id);
    });
  ' "$project_id"
}

wait_for_runtime() {
  local started
  local fields
  started="$(date +%s)"
  while true; do
    read_core_me
    if fields="$(runtime_fields)"; then
      IFS=$'\t' read -r project_id machine_id runtime_url <<<"$fields"
      if [[ -n "$project_id" && -n "$machine_id" && -n "$runtime_url" ]]; then
        return 0
      fi
    fi
    if node - "$me_json" <<'JS'
const fs = require("node:fs");
const me = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const failed = (me.agent_creation_requests || []).find((request) => request.status === "failed");
if (failed) {
  console.error(`Agent launch failed: ${failed.failure_message || failed.id}`);
  process.exit(0);
}
process.exit(1);
JS
    then
      return 1
    fi
    if (( "$(date +%s)" - started >= 600 )); then
      echo "Core did not report a launched Apple Container runtime within 600s" >&2
      return 1
    fi
    sleep 2
  done
}

chat_state() {
  curl -fsS --max-time 30 \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/state" \
    >"$chat_state_json"
}

start_chat_updates() {
  if [[ -n "$updates_pid" ]]; then
    kill "$updates_pid" >/dev/null 2>&1 || true
    wait "$updates_pid" >/dev/null 2>&1 || true
  fi
  curl -fsS --no-buffer \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/updates" \
    >/dev/null 2>&1 &
  updates_pid=$!
}

wait_for_connected_chat() {
  local started
  started="$(date +%s)"
  while true; do
    if chat_state && node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
process.exit((state.rooms || []).some((room) => room.is_agent_chat && room.state === "Connected") ? 0 : 1);
JS
    then
      return 0
    fi
    if (( "$(date +%s)" - started >= 180 )); then
      echo "Hosted Web Device did not establish the agent chat within 180s" >&2
      return 1
    fi
    sleep 2
  done
}

max_remote_seq() {
  node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const seq = (state.messages || [])
  .filter((message) => !message.is_mine)
  .reduce((max, message) => Math.max(max, Number(message.seq) || 0), 0);
process.stdout.write(String(seq));
JS
}

send_chat_message() {
  local text="$1"
  node - "$chat_state_json" "$text" >"$chat_action_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const text = process.argv[3];
const room = (state.rooms || []).find((candidate) => candidate.is_agent_chat && candidate.state === "Connected");
if (!room) throw new Error("no connected agent room");
const topic = (state.topics || []).find((candidate) => candidate.room_id === room.room_id);
const chat = topic?.chats?.find((candidate) => candidate.chat_id === state.selected_chat_id)
  || topic?.chats?.find((candidate) => candidate.active);
const action = topic && chat
  ? { SendChatMessage: { room_id: room.room_id, topic_id: topic.topic_id, chat_id: chat.chat_id, text } }
  : topic
    ? { SendTopicMessage: { room_id: room.room_id, topic_id: topic.topic_id, text } }
    : { SendMessage: { room_id: room.room_id, text } };
process.stdout.write(JSON.stringify(action));
JS
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$chat_action_json" \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/actions" \
    >"$chat_state_json"
}

wait_for_remote_reply_after() {
  local previous_seq="$1"
  local started
  started="$(date +%s)"
  while true; do
    chat_state
    if node - "$chat_state_json" "$previous_seq" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const previous = Number(process.argv[3]);
process.exit((state.messages || []).some((message) => !message.is_mine && Number(message.seq) > previous) ? 0 : 1);
JS
    then
      return 0
    fi
    if (( "$(date +%s)" - started >= 240 )); then
      echo "Hermes did not answer the real Hosted Web Device message within 240s" >&2
      return 1
    fi
    sleep 2
  done
}

send_and_require_reply() {
  local text="$1"
  local before
  chat_state
  before="$(max_remote_seq)"
  send_chat_message "$text"
  wait_for_remote_reply_after "$before"
}

restart_process() {
  local process="$1"
  # A dependency restart can leave dependants in process-compose's Skipped
  # state. `process restart` does not revive a skipped process, so model the
  # actual outage explicitly and always finish with a start transition.
  process-compose \
    --use-uds \
    --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
    process stop "$process" >/dev/null || true

  local stopped_at state
  stopped_at="$(date +%s)"
  while true; do
    state="$(
      process-compose \
        --use-uds \
        --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
        process get "$process" --output json 2>/dev/null || true
    )"
    if node -e '
      const state = JSON.parse(process.argv[1] || "[]")[0];
      process.exit(state?.status !== "Running" ? 0 : 1);
    ' "$state"; then
      break
    fi
    if (( "$(date +%s)" - stopped_at >= 60 )); then
      echo "$process did not finish stopping within 60s" >&2
      return 1
    fi
    sleep 1
  done

  process-compose \
    --use-uds \
    --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
    process start "$process" >/dev/null 2>&1 || true

  local started
  started="$(date +%s)"
  while true; do
    state="$(
      process-compose \
        --use-uds \
        --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
        process get "$process" --output json 2>/dev/null || true
    )"
    if node -e '
      const state = JSON.parse(process.argv[1] || "[]")[0];
      process.exit(state?.status === "Running" && state?.is_ready === "Ready" ? 0 : 1);
    ' "$state"; then
      return 0
    fi
    # Starting a dependant before process-compose has observed its dependency
    # as Ready can leave it Skipped even though the CLI returned success.
    # Retry the idempotent start once readiness catches up.
    process-compose \
      --use-uds \
      --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
      process start "$process" >/dev/null 2>&1 || true
    if (( "$(date +%s)" - started >= 120 )); then
      echo "$process did not return to Ready within 120s" >&2
      return 1
    fi
    sleep 1
  done
}

container_started_at() {
  container inspect "$container_machine_id" 2>/dev/null | node -e '
    let body = "";
    process.stdin.on("data", (chunk) => body += chunk);
    process.stdin.on("end", () => {
      const value = JSON.parse(body);
      process.stdout.write(String(value?.[0]?.status?.startedDate || ""));
    });
  ' 2>/dev/null || true
}

runtime_agent_npub() {
  curl -fsS --max-time 5 "$runtime_url/healthz" | node -e '
    let body = "";
    process.stdin.on("data", (chunk) => body += chunk);
    process.stdin.on("end", () => {
      const value = JSON.parse(body);
      const npub = String(value.agent_npub || value.npub || "");
      if (!value.ready || !npub.startsWith("npub1")) process.exit(1);
      process.stdout.write(npub);
    });
  '
}

brain_browser_smoke() {
  local action="$1"
  local expected_text="${2:-}"
  (
    cd "$dashboard_dir"
    DEVFINITY_BRAIN_MACHINE_ID="$machine_id" \
      DEVFINITY_BRAIN_AGENT_NPUB="$agent_npub_before" \
      DEVFINITY_BRAIN_EXPECTED_TEXT="$expected_text" \
      node --import tsx scripts/devfinity-brain-smoke.ts "$action"
  )
}

paired_personal_vault_id() {
  container exec "$container_machine_id" fbrain vault list --json >"$brain_vaults_json"
  node - "$brain_vaults_json" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const personal = (response.vaults || []).find(
  (vault) => vault.kind === "personal" && vault.role === "member"
);
if (!personal?.vaultId) {
  throw new Error("Agent Principal cannot discover the paired user-owned Personal Vault");
}
process.stdout.write(personal.vaultId);
JS
}

open_and_sync_agent_workspace() {
  container exec "$container_machine_id" fbrain open "$brain_vault_id" --json >"$brain_open_json"
  node - "$brain_open_json" "$brain_tree" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (response.path !== process.argv[3]) {
  throw new Error(`fbrain opened ${response.path}, expected durable tree ${process.argv[3]}`);
}
JS
  container exec -w "$brain_tree" "$container_machine_id" fbrain sync now --json \
    >"$brain_sync_json"
  assert_agent_workspace_scope
  container exec "$container_machine_id" /bin/bash -lc '
    test "$FINITE_HOME" = /data/agent
    test "$FBRAIN_CONFIG_DIR" = /data/agent/fbrain
    test "$FBRAIN_WORKING_TREE_ROOT" = /data/workspace/finitebrain
    test -f /data/agent/identity/identity.json
    test -d /data/agent/fbrain
    test ! -e /root/.finite/identity/identity.json
    test ! -e /root/.finitebrain
    test ! -e /root/finitebrain
  '
}

assert_agent_workspace_scope() {
  container exec "$container_machine_id" cat \
    "$brain_tree/.finitebrain/vault-directory.json" >"$brain_directory_json"
  container exec "$container_machine_id" cat \
    "$brain_tree/.finitebrain/working-tree-state.json" >"$brain_tree_state_json"
  node - \
    "$brain_directory_json" \
    "$brain_tree_state_json" \
    "$brain_vault_id" \
    "$agent_npub_before" <<'JS'
const fs = require("node:fs");
const directory = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const treeState = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const expectedVaultId = process.argv[4];
const agentNpub = process.argv[5];
if (directory.vault?.id !== expectedVaultId || directory.vault?.kind !== "personal") {
  throw new Error("Agent Working Tree is not the paired user-owned Personal Vault");
}
if (!directory.vault.ownerNpub || directory.vault.ownerNpub === agentNpub) {
  throw new Error("Agent Working Tree must name the distinct user owner, never the Agent Principal");
}
const roots = treeState.folderRoots || [];
if (
  roots.length !== 1 ||
  roots[0].folderId !== "agent-workspace" ||
  roots[0].path !== "agent-workspace" ||
  roots[0].canRead !== true ||
  roots[0].metadataOnly !== false
) {
  throw new Error(
    `Agent Working Tree must expose exactly one readable Agent Workspace Folder: ${JSON.stringify(roots)}`
  );
}
JS
}

write_agent_workspace_note() {
  container exec \
    -e "DEVFINITY_BRAIN_PROOF=$brain_proof" \
    -w "$brain_tree/agent-workspace" \
    "$container_machine_id" \
    /bin/bash -lc '
      umask 077
      printf "# %s\n\nWritten by the paired Agent Principal through fbrain.\n" \
        "$DEVFINITY_BRAIN_PROOF" >devfinity-agent-proof.md
    '
  container exec -w "$brain_tree" "$container_machine_id" fbrain sync now --json \
    >"$brain_sync_json"
}

requesting_user_account_id() {
  node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const accountId = String(state.identity?.account_id || "");
if (!/^[0-9a-f]{64}$/u.test(accountId)) {
  throw new Error("Hosted Web Device did not expose the authenticated human account id");
}
process.stdout.write(accountId);
JS
}

publish_private_requesting_user_site() {
  local init_fields
  sites_run_id="$(date +%s)-$$"
  sites_slug="devfinity-private-${sites_run_id}"
  sites_marker="Devfinity private Sites ${sites_run_id}"
  sites_tree="/data/workspace/${sites_slug}"
  requesting_user_id="$(requesting_user_account_id)"

  container exec \
    -e "DEVFINITY_SITES_SLUG=$sites_slug" \
    -e "DEVFINITY_SITES_MARKER=$sites_marker" \
    "$container_machine_id" \
    /bin/bash -lc '
      set -euo pipefail
      tree="/data/workspace/$DEVFINITY_SITES_SLUG"
      test ! -e "$tree"
      mkdir -p "$tree/site"
      printf "%s\n" \
        "[project]" \
        "slug = \"$DEVFINITY_SITES_SLUG\"" \
        "" \
        "[outputs.site]" \
        "kind = \"site\"" \
        "site_name = \"$DEVFINITY_SITES_SLUG\"" \
        "branch = \"main\"" \
        "path = \"site\"" \
        "spa = false" >"$tree/finite.toml"
      printf "<h1>%s</h1>\n" "$DEVFINITY_SITES_MARKER" >"$tree/site/index.html"
    '

  container exec "$container_machine_id" fsite auth register --output json \
    >"$sites_auth_json"
  container exec -w "$sites_tree" "$container_machine_id" \
    fsite project init \
      --config finite.toml \
      --requesting-user-npub "$requesting_user_id" \
      --dry-run \
      --output json \
    >"$sites_dry_run_json"
  container exec -w "$sites_tree" "$container_machine_id" \
    fsite project init \
      --config finite.toml \
      --requesting-user-npub "$requesting_user_id" \
      --output json \
    >"$sites_init_json"

  init_fields="$(node - "$sites_init_json" "$sites_slug" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const expectedSlug = process.argv[3];
const output = response.outputs?.[0];
if (
  response.slug !== expectedSlug ||
  !response.requesting_user_npub?.startsWith("npub1") ||
  !output?.requesting_user_shared ||
  output.visibility !== "private" ||
  typeof output.output_id !== "string" ||
  typeof output.output_url !== "string" ||
  typeof response.git_remote_url !== "string"
) {
  throw new Error(`Project Init did not create the private requesting-user Share: ${JSON.stringify(response)}`);
}
process.stdout.write([
  output.output_id,
  output.output_url,
  response.git_remote_url,
].join("\t"));
JS
)"
  IFS=$'\t' read -r sites_output_id sites_url sites_git_remote <<<"$init_fields"

  container exec \
    -e GIT_CONFIG_GLOBAL=/data/agent/gitconfig \
    "$container_machine_id" \
    fsite auth git "$sites_slug" --store --output json \
    >"$sites_git_auth_json"
  container exec \
    -e GIT_CONFIG_GLOBAL=/data/agent/gitconfig \
    -e "DEVFINITY_SITES_GIT_REMOTE=$sites_git_remote" \
    -w "$sites_tree" \
    "$container_machine_id" \
    /bin/bash -lc '
      set -euo pipefail
      git init -b main
      git config user.name "Devfinity Sites Smoke"
      git config user.email "devfinity-sites-smoke@finite.invalid"
      git add finite.toml site
      git commit -m "Publish private requesting-user smoke site"
      git remote add finite "$DEVFINITY_SITES_GIT_REMOTE"
      git push finite main
    '

  local started status
  started="$(date +%s)"
  while true; do
    status="$(curl -sS --max-time 5 -o /dev/null -w '%{http_code}' "$sites_url" || true)"
    if [[ "$status" == "401" ]]; then
      break
    fi
    if (( "$(date +%s)" - started >= 90 )); then
      echo "Private Sites Output did not publish at $sites_url within 90s; last status $status" >&2
      return 1
    fi
    sleep 1
  done
  assert_site_unauthorized
  issue_and_redeem_site_preview "$sites_cookie_jar_before"
  echo "agent publish -> requesting user private preview ok: $sites_url"
}

issue_and_redeem_site_preview() {
  local cookie_jar="$1"
  local redeem_url status
  node -e 'process.stdout.write(JSON.stringify({ url: process.argv[1] }))' \
    "$sites_url" >"$sites_preview_request_json"
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$sites_preview_request_json" \
    "$dashboard_origin/api/site-previews/machines/$machine_id/session" \
    >"$sites_preview_response_json"
  redeem_url="$(node - "$sites_preview_response_json" "$sites_url" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const original = new URL(process.argv[3]).toString();
const redeem = new URL(String(response.url || ""));
if (
  redeem.origin !== new URL(original).origin ||
  redeem.pathname !== "/_finite/auth" ||
  !/^[0-9a-f]{64}$/u.test(redeem.searchParams.get("native_token") || "")
) {
  throw new Error(`Dashboard did not return a native Sites redemption URL: ${JSON.stringify(response)}`);
}
process.stdout.write(redeem.toString());
JS
)"
  status="$(curl -sS --max-time 15 \
    -D "$sites_redeem_headers" \
    -o /dev/null \
    -c "$cookie_jar" \
    -w '%{http_code}' \
    "$redeem_url")"
  if [[ "$status" != "303" ]]; then
    echo "Sites redemption returned HTTP $status instead of 303" >&2
    return 1
  fi
  assert_site_cookie_works "$cookie_jar"
}

assert_site_cookie_works() {
  local cookie_jar="$1"
  local body
  body="$(curl -fsS --max-time 15 -b "$cookie_jar" "$sites_url")"
  if [[ "$body" != *"$sites_marker"* ]]; then
    echo "Authenticated Sites response did not contain the smoke marker" >&2
    return 1
  fi
}

assert_site_unauthorized() {
  local status
  status="$(curl -sS --max-time 15 -o /dev/null -w '%{http_code}' "$sites_url")"
  if [[ "$status" != "401" ]]; then
    echo "Private Sites Output returned HTTP $status without a Viewer Cookie" >&2
    return 1
  fi
}

revoke_requesting_user_site() {
  container exec -w "$sites_tree" "$container_machine_id" \
    fsite project share "$sites_slug" "$sites_output_id" \
      --remove-npub "$requesting_user_id" \
      --output json \
    >"$sites_revoke_json"
  node - "$sites_revoke_json" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if ((response.shared_npubs || []).length !== 0) {
  throw new Error(`Requesting-user Share was not revoked: ${JSON.stringify(response)}`);
}
JS

  local status
  for cookie_jar in "$sites_cookie_jar_before" "$sites_cookie_jar_after"; do
    status="$(curl -sS --max-time 15 -o /dev/null -b "$cookie_jar" -w '%{http_code}' "$sites_url")"
    if [[ "$status" != "401" ]]; then
      echo "Revoked Sites Viewer Cookie returned HTTP $status instead of 401" >&2
      return 1
    fi
  done
  assert_site_unauthorized

  node -e 'process.stdout.write(JSON.stringify({ url: process.argv[1] }))' \
    "$sites_url" >"$sites_preview_request_json"
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$sites_preview_request_json" \
    "$dashboard_origin/api/site-previews/machines/$machine_id/session" \
    >"$sites_preview_response_json"
  node - "$sites_preview_response_json" "$sites_url" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (new URL(String(response.url || "")).toString() !== new URL(process.argv[3]).toString()) {
  throw new Error(`Dashboard unexpectedly minted a Sites viewer session after revocation: ${JSON.stringify(response)}`);
}
JS
  echo "requesting-user Share revocation invalidated live and future Sites sessions"
}

need container
need curl
need node
need process-compose

if [[ "${DEVFINITY_PROFILE:-}" != "apple-saas" ]]; then
  echo "devfinity SaaS smoke requires the apple-saas profile" >&2
  exit 64
fi
if [[ "${DEVFINITY_BRAIN_ONLY_SMOKE:-0}" != "0" && "${DEVFINITY_BRAIN_ONLY_SMOKE:-0}" != "1" ]]; then
  echo "DEVFINITY_BRAIN_ONLY_SMOKE must be 0 or 1" >&2
  exit 64
fi
if [[ "${DEVFINITY_SITES_ONLY_SMOKE:-0}" != "0" && "${DEVFINITY_SITES_ONLY_SMOKE:-0}" != "1" ]]; then
  echo "DEVFINITY_SITES_ONLY_SMOKE must be 0 or 1" >&2
  exit 64
fi

core_url="${FC_CORE_URL:?}"
dashboard_url="${FC_DASHBOARD_URL:?}"
dashboard_origin="${dashboard_url%/dashboard}"
chat_url="${FINITECHAT_SERVER_URL:?}"
hosted_device_url="${FC_HOSTED_WEB_DEVICE_URL:?}"
sites_api_url="${FC_SITES_UPSTREAM_URL:?}"
state_dir="${DEVFINITY_STATE_DIR:?}"
dashboard_dir="$(pwd)/finitecomputer-v2/apps/dashboard"
me_json="$state_dir/saas-smoke-core-me.json"
chat_state_json="$state_dir/saas-smoke-chat-state.json"
chat_action_json="$state_dir/saas-smoke-chat-action.json"
brain_vaults_json="$state_dir/saas-smoke-brain-vaults.json"
brain_open_json="$state_dir/saas-smoke-brain-open.json"
brain_sync_json="$state_dir/saas-smoke-brain-sync.json"
brain_directory_json="$state_dir/saas-smoke-brain-directory.json"
brain_tree_state_json="$state_dir/saas-smoke-brain-tree-state.json"
sites_auth_json="$state_dir/saas-smoke-sites-auth.json"
sites_dry_run_json="$state_dir/saas-smoke-sites-dry-run.json"
sites_init_json="$state_dir/saas-smoke-sites-init.json"
sites_git_auth_json="$state_dir/saas-smoke-sites-git-auth.json"
sites_preview_request_json="$state_dir/saas-smoke-sites-preview-request.json"
sites_preview_response_json="$state_dir/saas-smoke-sites-preview-response.json"
sites_redeem_headers="$state_dir/saas-smoke-sites-redeem.headers"
sites_cookie_jar_before="$state_dir/saas-smoke-sites-before.cookies"
sites_cookie_jar_after="$state_dir/saas-smoke-sites-after.cookies"
sites_revoke_json="$state_dir/saas-smoke-sites-revoke.json"
track_sensitive_file "$sites_git_auth_json"
track_sensitive_file "$sites_preview_response_json"
track_sensitive_file "$sites_redeem_headers"
track_sensitive_file "$sites_cookie_jar_before"
track_sensitive_file "$sites_cookie_jar_after"

read_core_me
if ! runtime_fields >/dev/null 2>&1; then
  if node - "$me_json" <<'JS'
const fs = require("node:fs");
const me = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
process.exit((me.agent_creation_requests || []).some((request) => ["requested", "launching"].includes(request.status)) ? 0 : 1);
JS
  then
    echo "waiting for the existing real agent launch"
  else
    run_id="$(date +%s)-$$"
    issue_json="$state_dir/saas-smoke-issued-launch-code.json"
    launch_code_file="$state_dir/saas-smoke-launch-code.txt"
    track_sensitive_file "$issue_json"
    track_sensitive_file "$launch_code_file"
    umask 077
    operator_config="$state_dir/saas-smoke-operator-auth-$$-$RANDOM.conf"
    track_sensitive_file "$operator_config"
    printf 'header = "authorization: Bearer %s"\n' \
      "$(tr -d '\n' <"$state_dir/workos-fixture/operator.jwt")" >"$operator_config"
    curl -fsS --config "$operator_config" \
      -H 'content-type: application/json' \
      --data '{"name":"Devfinity Apple smoke","codeCount":1,"expiresInHours":24}' \
      "$core_url/api/core/v1/admin/launch-code-batches" >"$issue_json"
    rm -f "$operator_config"
    node - "$issue_json" "$launch_code_file" <<'JS'
const fs = require("node:fs");
const code = JSON.parse(fs.readFileSync(process.argv[2], "utf8"))?.codes?.[0]?.code;
if (typeof code !== "string" || !code) throw new Error("Core did not return a smoke Launch Code");
fs.writeFileSync(process.argv[3], code, { mode: 0o600 });
JS
    rm -f "$issue_json"
    curl -fsS \
      -o /dev/null \
      -X POST \
      --data-urlencode "displayName=Devfinity Apple Agent $run_id" \
      --data-urlencode "access=launch-code" \
      --data-urlencode "launchCode@$launch_code_file" \
      --data-urlencode "idempotencyKey=devfinity-apple-$run_id" \
      "$dashboard_url/agent-creation-requests"
    rm -f "$launch_code_file"
    echo "submitted the dashboard agent form"
  fi
fi

wait_for_runtime
container_machine_id="$(runtime_container_id)"
wait_http "Agent Runtime" "$runtime_url/healthz" 180
wait_http "Agent contact" "$runtime_url/contact" 180
start_chat_updates
wait_for_connected_chat
if [[ "${DEVFINITY_BRAIN_ONLY_SMOKE:-0}" == "0" && "${DEVFINITY_SITES_ONLY_SMOKE:-0}" == "0" ]]; then
  send_and_require_reply "Reply briefly with: devfinity apple chat works"
else
  echo "focused smoke: Hosted Web Device connected; real inference reply skipped"
fi

agent_npub_before="$(runtime_agent_npub)"
brain_browser_smoke pair
brain_vault_id="$(paired_personal_vault_id)"
brain_tree="/data/workspace/finitebrain/$brain_vault_id"
brain_proof="Devfinity Agent Brain Proof $(date +%s)-$$"
open_and_sync_agent_workspace
write_agent_workspace_note
brain_browser_smoke assert-note "$brain_proof"
publish_private_requesting_user_site

restart_process finitechat
wait_http "Finite Chat after restart" "$chat_url/health" 120
restart_process hosted-web-device
wait_http "Hosted Web Device after restart" "$hosted_device_url/healthz" 120
restart_process finitesites
wait_http "Finite Sites after restart" "$sites_api_url/api/v1/healthz" 120
assert_site_cookie_works "$sites_cookie_jar_before"
issue_and_redeem_site_preview "$sites_cookie_jar_after"
start_chat_updates
wait_for_connected_chat
if [[ "${DEVFINITY_BRAIN_ONLY_SMOKE:-0}" == "0" && "${DEVFINITY_SITES_ONLY_SMOKE:-0}" == "0" ]]; then
  send_and_require_reply "Reply briefly with: chat services healed"
fi

runtime_started_before="$(container_started_at)"
curl_customer \
  -H 'content-type: application/json' \
  -X POST \
  --data '{}' \
  "$core_url/api/core/v1/me/projects/$project_id/runtime/restart" \
  >/dev/null
restart_started="$(date +%s)"
while true; do
  runtime_started_after="$(container_started_at)"
  if [[ -n "$runtime_started_after" && "$runtime_started_after" != "$runtime_started_before" ]]; then
    break
  fi
  if (( "$(date +%s)" - restart_started >= 180 )); then
    echo "Runner did not restart Apple Container $container_machine_id within 180s" >&2
    exit 1
  fi
  sleep 2
done
wait_http "Agent Runtime after restart" "$runtime_url/healthz" 180
agent_npub_after="$(runtime_agent_npub)"
if [[ "$agent_npub_after" != "$agent_npub_before" ]]; then
  echo "Agent Principal changed across Apple Container restart" >&2
  exit 1
fi
container exec "$container_machine_id" test -f \
  "$brain_tree/agent-workspace/devfinity-agent-proof.md"
if [[ "$(paired_personal_vault_id)" != "$brain_vault_id" ]]; then
  echo "Agent lost its paired Personal Vault across Apple Container restart" >&2
  exit 1
fi
container exec -w "$brain_tree" "$container_machine_id" fbrain sync now --json \
  >"$brain_sync_json"
assert_agent_workspace_scope
brain_browser_smoke assert-note "$brain_proof"
assert_site_cookie_works "$sites_cookie_jar_before"
assert_site_cookie_works "$sites_cookie_jar_after"
revoke_requesting_user_site
wait_for_connected_chat
if [[ "${DEVFINITY_BRAIN_ONLY_SMOKE:-0}" == "0" && "${DEVFINITY_SITES_ONLY_SMOKE:-0}" == "0" ]]; then
  send_and_require_reply "Reply briefly with: runtime restart healed"
fi

echo "devfinity real SaaS smoke passed"
echo "project_id=$project_id"
echo "runtime_id=$machine_id"
echo "source_machine_id=$container_machine_id"
