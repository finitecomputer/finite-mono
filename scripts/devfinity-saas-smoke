#!/usr/bin/env bash
set -euo pipefail

declare -a sensitive_files=()
updates_pid=""

cleanup_sensitive_files() {
  if [[ -n "$updates_pid" ]]; then
    kill "$updates_pid" >/dev/null 2>&1 || true
    wait "$updates_pid" >/dev/null 2>&1 || true
  fi
  if (( ${#sensitive_files[@]} > 0 )); then
    rm -f -- "${sensitive_files[@]}"
  fi
}

track_sensitive_file() {
  sensitive_files+=("$1")
}

trap cleanup_sensitive_files EXIT

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 127
  fi
}

wait_http() {
  local name="$1"
  local url="$2"
  local timeout_secs="${3:-120}"
  local started
  started="$(date +%s)"
  until curl -fsS --max-time 3 "$url" >/dev/null 2>&1; do
    if (( "$(date +%s)" - started >= timeout_secs )); then
      echo "$name did not become ready at $url within ${timeout_secs}s" >&2
      return 1
    fi
    sleep 1
  done
}

read_core_me() {
  curl_customer "$core_url/api/core/v1/me" >"$me_json"
}

curl_customer() {
  local config_file="$state_dir/saas-smoke-curl-auth-$$-$RANDOM.conf"
  track_sensitive_file "$config_file"
  umask 077
  printf 'header = "authorization: Bearer %s"\n' \
    "$(tr -d '\n' <"$state_dir/workos-fixture/dashboard-customer.jwt")" >"$config_file"
  local status=0
  curl -fsS --config "$config_file" "$@" || status=$?
  if (( status != 0 )); then
    rm -f "$config_file"
    return "$status"
  fi
  rm -f "$config_file"
}

runtime_fields() {
  node - "$me_json" <<'JS'
const fs = require("node:fs");
const me = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const visible = (me.projects || []).find((entry) => entry.runtime);
if (!visible) process.exit(1);
const project = visible.project;
const runtime = visible.runtime;
const contact = new URL(runtime.contact_endpoint);
contact.pathname = contact.pathname.replace(/\/contact\/?$/, "");
process.stdout.write([
  project.id,
  runtime.id,
  contact.toString().replace(/\/$/, ""),
  project.agent_email || "",
].join("\t"));
JS
}

runtime_container_id() {
  container list --format json | node -e '
    const projectId = process.argv[1];
    let body = "";
    process.stdin.on("data", (chunk) => body += chunk);
    process.stdin.on("end", () => {
      const containers = JSON.parse(body);
      const runtime = containers.find((entry) =>
        entry?.configuration?.labels?.["computer.finite.v2.project_id"] === projectId
      );
      if (!runtime?.configuration?.id) process.exit(1);
      process.stdout.write(runtime.configuration.id);
    });
  ' "$project_id"
}

wait_for_runtime() {
  local started
  local fields
  started="$(date +%s)"
  while true; do
    read_core_me
    if fields="$(runtime_fields)"; then
      IFS=$'\t' read -r project_id machine_id runtime_url agent_email <<<"$fields"
      if [[ -n "$project_id" && -n "$machine_id" && -n "$runtime_url" && -n "$agent_email" ]]; then
        return 0
      fi
    fi
    if node - "$me_json" <<'JS'
const fs = require("node:fs");
const me = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const failed = (me.agent_creation_requests || []).find((request) => request.status === "failed");
if (failed) {
  console.error(`Agent launch failed: ${failed.failure_message || failed.id}`);
  process.exit(0);
}
process.exit(1);
JS
    then
      return 1
    fi
    if (( "$(date +%s)" - started >= 600 )); then
      echo "Core did not report a launched Apple Container runtime within 600s" >&2
      return 1
    fi
    sleep 2
  done
}

chat_state() {
  curl -fsS --max-time 30 \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/state" \
    >"$chat_state_json"
}

start_chat_updates() {
  if [[ -n "$updates_pid" ]]; then
    kill "$updates_pid" >/dev/null 2>&1 || true
    wait "$updates_pid" >/dev/null 2>&1 || true
  fi
  curl -fsS --no-buffer \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/updates" \
    >/dev/null 2>&1 &
  updates_pid=$!
}

wait_for_connected_chat() {
  local started
  started="$(date +%s)"
  while true; do
    if chat_state && node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
process.exit((state.rooms || []).some((room) => room.is_agent_chat && room.state === "Connected") ? 0 : 1);
JS
    then
      return 0
    fi
    if (( "$(date +%s)" - started >= 180 )); then
      echo "Hosted Web Device did not establish the agent chat within 180s" >&2
      return 1
    fi
    sleep 2
  done
}

max_remote_seq() {
  local room_id="$1"
  local topic_id="$2"
  local chat_id="$3"
  node - "$chat_state_json" "$room_id" "$topic_id" "$chat_id" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const [roomId, topicId, chatId] = process.argv.slice(3);
const seq = (state.messages || [])
  .filter((message) =>
    message.sender_account_id !== state.identity?.account_id
    && message.room_id === roomId
    && message.conversation_id === topicId
    && message.chat_id === chatId
  )
  .reduce((max, message) => Math.max(max, Number(message.seq) || 0), 0);
process.stdout.write(String(seq));
JS
}

selected_chat_route() {
  node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const roomId = state.hosted_agent_binding?.canonical_room_id;
const room = (state.rooms || []).find((candidate) =>
  candidate.room_id === roomId && candidate.state === "Connected"
);
const topics = (state.topics || []).filter((candidate) =>
  candidate.room_id === room?.room_id && !candidate.archived
);
const topic = topics.find((candidate) => candidate.topic_id === state.selected_topic_id)
  || topics.find((candidate) => candidate.topic_id === "home");
const chat = topic?.chats?.find((candidate) => candidate.chat_id === state.selected_chat_id)
  || topic?.chats?.find((candidate) => candidate.active)
  || topic?.chats?.[0];
if (!room || !topic || !chat) throw new Error("canonical Home chat is unavailable");
process.stdout.write([room.room_id, topic.topic_id, chat.chat_id].join("\t"));
JS
}

send_chat_message() {
  local text="$1"
  node - "$chat_state_json" "$text" >"$chat_action_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const text = process.argv[3];
const roomId = state.hosted_agent_binding?.canonical_room_id;
const room = (state.rooms || []).find((candidate) =>
  candidate.room_id === roomId && candidate.state === "Connected"
);
if (!room) throw new Error("no connected agent room");
const topics = (state.topics || []).filter((candidate) =>
  candidate.room_id === room.room_id && !candidate.archived
);
const topic = topics.find((candidate) => candidate.topic_id === state.selected_topic_id)
  || topics.find((candidate) => candidate.topic_id === "home");
const chat = topic?.chats?.find((candidate) => candidate.chat_id === state.selected_chat_id)
  || topic?.chats?.find((candidate) => candidate.active)
  || topic?.chats?.[0];
if (!topic || !chat) throw new Error("canonical Home chat is unavailable");
const action = {
  SendChatMessage: {
    room_id: room.room_id,
    topic_id: topic.topic_id,
    chat_id: chat.chat_id,
    text,
  },
};
process.stdout.write(JSON.stringify(action));
JS
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$chat_action_json" \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/actions" \
    >"$chat_state_json"
}

create_topic_and_require_first_chat() {
  local title="$1"
  local room_id
  chat_state
  room_id="$(node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const roomId = state.hosted_agent_binding?.canonical_room_id;
if (!roomId) throw new Error("canonical room is unavailable");
process.stdout.write(roomId);
JS
)"
  node - "$room_id" "$title" >"$chat_action_json" <<'JS'
const roomId = process.argv[2];
const title = process.argv[3];
if (!roomId || !title) throw new Error("canonical room or topic title is unavailable");
process.stdout.write(JSON.stringify({ CreateTopic: { room_id: roomId, title } }));
JS
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$chat_action_json" \
    "$dashboard_origin/api/chat/machines/$machine_id/hosted-device/actions" \
    >"$chat_state_json"
  node - "$chat_state_json" "$title" "$room_id" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const title = process.argv[3];
const roomId = process.argv[4];
const topic = (state.topics || []).find((candidate) =>
  candidate.room_id === roomId
  && candidate.topic_id === state.selected_topic_id
  && candidate.title === title
);
const chat = topic?.chats?.find((candidate) => candidate.chat_id === state.selected_chat_id);
if (!topic || !chat) {
  throw new Error("CreateTopic did not select its canonical first chat");
}
JS
}

scoped_working_present() {
  local room_id="$1"
  local topic_id="$2"
  local chat_id="$3"
  node - "$chat_state_json" "$room_id" "$topic_id" "$chat_id" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const [roomId, topicId, chatId] = process.argv.slice(3);
process.exit((state.typing_members || []).some((member) =>
  member.room_id === roomId
  && member.topic_id === topicId
  && member.chat_id === chatId
  && member.activity_kind === "working"
) ? 0 : 1);
JS
}

wait_for_scoped_working_clear() {
  local room_id="$1"
  local topic_id="$2"
  local chat_id="$3"
  local timeout_secs="${4:-5}"
  local started
  started="$(date +%s)"
  while true; do
    chat_state
    if ! scoped_working_present "$room_id" "$topic_id" "$chat_id"; then
      return 0
    fi
    if (( "$(date +%s)" - started >= timeout_secs )); then
      echo "scoped Working activity did not clear after Hermes completed" >&2
      return 1
    fi
    sleep 0.25
  done
}

wait_for_remote_reply_after() {
  local previous_seq="$1"
  local room_id="$2"
  local topic_id="$3"
  local chat_id="$4"
  local require_working="${5:-0}"
  local started
  local working_seen=0
  started="$(date +%s)"
  while true; do
    chat_state
    if scoped_working_present "$room_id" "$topic_id" "$chat_id"; then
      working_seen=1
    fi
    if node - "$chat_state_json" "$previous_seq" "$room_id" "$topic_id" "$chat_id" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const previous = Number(process.argv[3]);
const [roomId, topicId, chatId] = process.argv.slice(4);
process.exit((state.messages || []).some((message) =>
  message.sender_account_id !== state.identity?.account_id
  && Number(message.seq) > previous
  && message.room_id === roomId
  && message.conversation_id === topicId
  && message.chat_id === chatId
  && message.final_delivery === true
) ? 0 : 1);
JS
    then
      if [[ "$require_working" == "1" && "$working_seen" != "1" ]]; then
        echo "Hermes completed without observable scoped Working activity" >&2
        return 1
      fi
      wait_for_scoped_working_clear "$room_id" "$topic_id" "$chat_id"
      return 0
    fi
    # Finite Chat activity is ephemeral and may clear as soon as Hermes sends
    # its final response, before the Hosted Web Device has projected that
    # durable message. The dashboard keeps the submitted turn visibly Working
    # until final_delivery arrives, so require an observed activity handoff and
    # the durable final below without treating that transport race as failure.
    if (( "$(date +%s)" - started >= 240 )); then
      echo "Hermes did not answer the real Hosted Web Device message within 240s" >&2
      return 1
    fi
    sleep 0.25
  done
}

send_and_require_reply() {
  local text="$1"
  local before
  local room_id
  local topic_id
  local chat_id
  chat_state
  IFS=$'\t' read -r room_id topic_id chat_id <<<"$(selected_chat_route)"
  wait_for_scoped_working_clear "$room_id" "$topic_id" "$chat_id"
  before="$(max_remote_seq "$room_id" "$topic_id" "$chat_id")"
  send_chat_message "$text"
  wait_for_remote_reply_after "$before" "$room_id" "$topic_id" "$chat_id"
}

last_site_final_timestamp=0
sites_acceptance_room_id=""
sites_acceptance_topic_id=""
sites_acceptance_chat_id=""

send_site_and_require_ordered_chat() {
  local marker="$1"
  local before
  local room_id
  local topic_id
  local chat_id
  local result
  local final_timestamp
  local site_url
  local site_body
  local result_file
  chat_state
  IFS=$'\t' read -r room_id topic_id chat_id <<<"$(selected_chat_route)"
  if [[ -z "$sites_acceptance_room_id" ]]; then
    sites_acceptance_room_id="$room_id"
    sites_acceptance_topic_id="$topic_id"
    sites_acceptance_chat_id="$chat_id"
  elif [[ "$room_id" != "$sites_acceptance_room_id" \
    || "$topic_id" != "$sites_acceptance_topic_id" \
    || "$chat_id" != "$sites_acceptance_chat_id" ]]; then
    echo "selected chat route changed between Sites turns" >&2
    return 1
  fi
  wait_for_scoped_working_clear "$room_id" "$topic_id" "$chat_id"
  before="$(max_remote_seq "$room_id" "$topic_id" "$chat_id")"
  send_chat_message \
    "Use the installed Finite Sites skill to publish a minimal public Finite Site whose rendered page visibly contains only the exact marker ${marker}. This marker contains no private data, and this request is explicit approval to make that output public with the skill's documented public-sharing command. Actually publish it, verify it, and return verbatim the exact outputs[].output_url reported by fsite project status --output json in your final response. In this local test that authoritative URL will be an http://*.sites.localhost:<port>/ URL; never translate or synthesize a production hostname."
  wait_for_remote_reply_after "$before" "$room_id" "$topic_id" "$chat_id" 1

  result_file="$state_dir/saas-smoke-site-turn-result-$$-$RANDOM.txt"
  track_sensitive_file "$result_file"
  node - "$chat_state_json" "$before" "$room_id" "$topic_id" "$chat_id" "$sites_api_url" >"$result_file" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const previous = Number(process.argv[3]);
const [roomId, topicId, chatId] = process.argv.slice(4, 7);
const sitesApi = new URL(process.argv[7]);
const remote = (state.messages || []).filter((message) =>
  message.sender_account_id !== state.identity?.account_id
  && Number(message.seq) > previous
  && message.room_id === roomId
  && message.conversation_id === topicId
  && message.chat_id === chatId
);
if (remote.length === 0) throw new Error("site turn produced no scoped Agent messages");
for (let index = 1; index < remote.length; index += 1) {
  if (Number(remote[index].seq) <= Number(remote[index - 1].seq)) {
    throw new Error("site turn messages are not in strictly increasing durable order");
  }
}
const tools = remote.filter((message) => message.kind === "tool");
if (tools.length < 2) throw new Error("site turn did not expose representative tool progress");
if (tools.some((message) => message.edit_of_message_id)) {
  throw new Error("site turn rewrote an earlier tool bubble instead of appending progress");
}
const final = remote.findLast((message) => message.final_delivery === true);
if (!final) throw new Error("site turn has no final delivery");
const content = String(final.display_content || final.text || "");
const match = content.match(/https?:\/\/[^\s<>)\]},"\x27\x60*]+/u);
if (!match) throw new Error("site turn final delivery has no public URL");
const candidate = match[0].replace(/[.,;:!?]+$/u, "");
const url = new URL(candidate);
const oneLabelUnder = (hostname, base) => {
  const suffix = `.${base}`;
  if (!hostname.endsWith(suffix)) return false;
  const label = hostname.slice(0, -suffix.length);
  return Boolean(label) && !label.includes(".") && !["api", "git"].includes(label);
};
const productionOutput = url.protocol === "https:"
  && !url.port
  && (oneLabelUnder(url.hostname, "finite.chat")
    || oneLabelUnder(url.hostname, "docs.finite.chat"));
const localOutput = url.protocol === "http:"
  && sitesApi.protocol === "http:"
  && Boolean(url.port)
  && url.port === sitesApi.port
  && (oneLabelUnder(url.hostname, "sites.localhost")
    || oneLabelUnder(url.hostname, "docs.sites.localhost"));
if (url.username || url.password || (!productionOutput && !localOutput)) {
  throw new Error("site turn final delivery URL is not a Finite Sites output");
}
process.stdout.write(`${Number(final.timestamp_unix_seconds) || 0}\t${url.href}`);
JS
  result="$(cat "$result_file")"
  IFS=$'\t' read -r final_timestamp site_url <<<"$result"
  if (( final_timestamp <= 0 )); then
    echo "site turn final delivery has no live timestamp" >&2
    return 1
  fi
  if (( last_site_final_timestamp > 0 && final_timestamp <= last_site_final_timestamp )); then
    echo "resident Hermes timestamps did not advance between site turns" >&2
    return 1
  fi
  last_site_final_timestamp="$final_timestamp"
  site_body="$state_dir/saas-smoke-agent-site-${marker}.html"
  track_sensitive_file "$site_body"
  if ! curl -fsS --max-time 30 "$site_url" >"$site_body" \
    || ! grep -Fq -- "$marker" "$site_body"; then
    echo "published Finite Site did not render marker $marker at $site_url" >&2
    return 1
  fi
}

stop_process() {
  local process="$1"
  process-compose \
    --use-uds \
    --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
    process stop "$process" >/dev/null || true

  local stopped_at state
  stopped_at="$(date +%s)"
  while true; do
    state="$(
      process-compose \
        --use-uds \
        --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
        process get "$process" --output json 2>/dev/null || true
    )"
    if node -e '
      const state = JSON.parse(process.argv[1] || "[]")[0];
      process.exit(state?.status !== "Running" ? 0 : 1);
    ' "$state"; then
      break
    fi
    if (( "$(date +%s)" - stopped_at >= 60 )); then
      echo "$process did not finish stopping within 60s" >&2
      return 1
    fi
    sleep 1
  done
}

restart_process() {
  local process="$1"
  # A dependency restart can leave dependants in process-compose's Skipped
  # state. `process restart` does not revive a skipped process, so model the
  # actual outage explicitly and always finish with a start transition.
  stop_process "$process"

  process-compose \
    --use-uds \
    --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
    process start "$process" >/dev/null 2>&1 || true

  local started
  started="$(date +%s)"
  while true; do
    state="$(
      process-compose \
        --use-uds \
        --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
        process get "$process" --output json 2>/dev/null || true
    )"
    if node -e '
      const state = JSON.parse(process.argv[1] || "[]")[0];
      process.exit(state?.status === "Running" && state?.is_ready === "Ready" ? 0 : 1);
    ' "$state"; then
      return 0
    fi
    # Starting a dependant before process-compose has observed its dependency
    # as Ready can leave it Skipped even though the CLI returned success.
    # Retry the idempotent start once readiness catches up.
    process-compose \
      --use-uds \
      --unix-socket "${DEVFINITY_PROCESS_COMPOSE_SOCKET:?}" \
      process start "$process" >/dev/null 2>&1 || true
    if (( "$(date +%s)" - started >= 120 )); then
      echo "$process did not return to Ready within 120s" >&2
      return 1
    fi
    sleep 1
  done
}

reset_brain_setup_matrix_state() {
  # Wait for SQLite's owning process to exit before unlinking the database.
  # Otherwise the still-open connection can recreate sidecars against an
  # unlinked main file and leave the next scenario with no schema.
  stop_process finite-brain
  rm -f -- \
    "$state_dir/finite-brain/finite-brain.sqlite3" \
    "$state_dir/finite-brain/finite-brain.sqlite3-shm" \
    "$state_dir/finite-brain/finite-brain.sqlite3-wal"
  container exec "$container_machine_id" /bin/bash -lc \
    'rm -rf /data/agent/fbrain /data/workspace/finitebrain'
  restart_process finite-brain
  wait_http "FiniteBrain matrix reset" "${FINITE_BRAIN_URL:?}/health" 120
}

assert_agent_brain_list() {
  local expected_kind="$1"
  local expected_role="$2"
  local expected_count="$3"
  container exec "$container_machine_id" fbrain brain list --json >"$brains_json"
  node - "$brains_json" "$expected_kind" "$expected_role" "$expected_count" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const [kind, role, countText] = process.argv.slice(3);
const brains = response.brains || [];
const count = Number(countText);
if (brains.length !== count) {
  throw new Error(`expected ${count} agent-visible Brains, received ${JSON.stringify(brains)}`);
}
if (count && (brains[0].kind !== kind || brains[0].role !== role)) {
  throw new Error(`expected ${kind}/${role}, received ${JSON.stringify(brains[0])}`);
}
JS
}

agent_visible_brain_id() {
  local expected_kind="$1"
  local expected_role="$2"
  assert_agent_brain_list "$expected_kind" "$expected_role" 1
  node - "$brains_json" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
process.stdout.write(response.brains[0].brainId);
JS
}

assert_agent_brain_shape() {
  local brain_id="$1"
  local expected_folder_count="$2"
  local expected_admin_count="$3"
  local metadata_json="$state_dir/brain-matrix-metadata.json"
  container exec "$container_machine_id" fbrain brain metadata "$brain_id" --json >"$metadata_json"
  node - "$metadata_json" "$brain_id" "$expected_folder_count" "$expected_admin_count" <<'JS'
const fs = require("node:fs");
const value = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const [brainId, folderCountText, adminCountText] = process.argv.slice(3);
const folderCount = Number(folderCountText);
const adminCount = Number(adminCountText);
if (value.brainId !== brainId) throw new Error(`expected ${brainId}, received ${value.brainId}`);
if (value.folders.length !== folderCount) throw new Error(`expected ${folderCount} Folders, received ${JSON.stringify(value.folders)}`);
if (value.admins.length !== adminCount || new Set(value.admins).size !== value.admins.length) {
  throw new Error(`expected ${adminCount} unique admins, received ${JSON.stringify(value.admins)}`);
}
if (folderCount === 0 && value.grantCount !== 0) throw new Error(`empty Brain has ${value.grantCount} grants`);
if ((value.identities || []).some((identity) => !identity.display)) throw new Error("identity display metadata is empty");
JS
}

browser_brain_id() {
  local action="$1"
  local expected_text="${2:-}"
  local target_brain_id="${3:-}"
  local output
  output="$(brain_browser_smoke "$action" "$expected_text" "$target_brain_id")"
  printf '%s\n' "$output" >&2
  sed -n 's/^BRAIN_ID=//p' <<<"$output" | tail -1
}

run_brain_setup_matrix() {
  local requester_npub
  local agent_id
  local browser_id
  local org_id="matrix-agent-org"
  requester_npub="$(requesting_user_account_id)"

  reset_brain_setup_matrix_state
  container exec "$container_machine_id" fbrain brain bootstrap-personal --json >/dev/null
  container exec "$container_machine_id" fbrain brain bootstrap-personal --json >/dev/null
  agent_id="$(agent_visible_brain_id personal personal_agent)"
  assert_agent_brain_shape "$agent_id" 0 0
  browser_id="$(browser_brain_id assert-existing-personal)"
  [[ "$browser_id" == "$agent_id" ]] || { echo "agent-first Personal Brain ids differ" >&2; return 1; }
  container exec "$container_machine_id" fbrain folder create matrix-agent-personal-folder \
    --brain "$agent_id" --name "Matrix Agent Personal Folder" --path matrix-agent-personal-folder --json >/dev/null
  assert_agent_brain_shape "$agent_id" 1 0
  brain_browser_smoke assert-folder "matrix-agent-personal-folder" "$agent_id"

  reset_brain_setup_matrix_state
  container exec "$container_machine_id" fbrain brain create "$org_id" \
    --kind organization \
    --name "Matrix Agent Org" \
    --requesting-user-npub "$requester_npub" \
    --json >/dev/null
  container exec "$container_machine_id" fbrain brain create "$org_id" \
    --kind organization \
    --name "Matrix Agent Org" \
    --requesting-user-npub "$requester_npub" \
    --json >/dev/null
  agent_id="$(agent_visible_brain_id organization admin)"
  [[ "$agent_id" == "$org_id" ]] || { echo "idempotent Org create changed its id" >&2; return 1; }
  assert_agent_brain_shape "$agent_id" 0 2
  browser_id="$(browser_brain_id assert-org-first "$org_id")"
  [[ "$browser_id" == "$agent_id" ]] || { echo "agent-first Org Brain ids differ" >&2; return 1; }
  container exec "$container_machine_id" fbrain folder create matrix-agent-org-folder \
    --brain "$agent_id" --name "Matrix Agent Org Folder" --path matrix-agent-org-folder --json >/dev/null
  assert_agent_brain_shape "$agent_id" 1 2
  brain_browser_smoke assert-folder "matrix-agent-org-folder" "$agent_id"

  reset_brain_setup_matrix_state
  browser_id="$(browser_brain_id bootstrap)"
  agent_id="$(agent_visible_brain_id personal personal_agent)"
  [[ "$browser_id" == "$agent_id" ]] || { echo "user-first Personal Brain ids differ" >&2; return 1; }
  assert_agent_brain_shape "$agent_id" 0 0
  brain_browser_smoke create-folder "Matrix User Personal Folder" "$browser_id"
  assert_agent_brain_shape "$agent_id" 1 0

  reset_brain_setup_matrix_state
  browser_id="$(browser_brain_id create-org-agent "Matrix User Agent Org")"
  agent_id="$(agent_visible_brain_id organization admin)"
  [[ "$browser_id" == "$agent_id" ]] || { echo "user-first paired Org Brain ids differ" >&2; return 1; }
  assert_agent_brain_shape "$agent_id" 0 2
  brain_browser_smoke create-folder "Matrix User Org Folder" "$browser_id"
  assert_agent_brain_shape "$agent_id" 1 2

  reset_brain_setup_matrix_state
  browser_id="$(browser_brain_id create-org-human "Matrix Human Only Org")"
  assert_agent_brain_list organization admin 0
  brain_browser_smoke create-folder "Matrix Human Only Folder" "$browser_id"
  assert_agent_brain_list organization admin 0

  echo "devfinity Brain setup/reconciliation matrix passed"
}

container_started_at() {
  container inspect "$container_machine_id" 2>/dev/null | node -e '
    let body = "";
    process.stdin.on("data", (chunk) => body += chunk);
    process.stdin.on("end", () => {
      const value = JSON.parse(body);
      process.stdout.write(String(value?.[0]?.status?.startedDate || ""));
    });
  ' 2>/dev/null || true
}

runtime_agent_npub() {
  curl -fsS --max-time 5 "$runtime_url/healthz" | node -e '
    let body = "";
    process.stdin.on("data", (chunk) => body += chunk);
    process.stdin.on("end", () => {
      const value = JSON.parse(body);
      const npub = String(value.agent_npub || value.npub || "");
      if (!value.ready || !npub.startsWith("npub1")) process.exit(1);
      process.stdout.write(npub);
    });
  '
}

brain_browser_smoke() {
  local action="$1"
  local expected_text="${2:-}"
  local target_brain_id="${3:-}"
  (
    cd "$dashboard_dir"
      DEVFINITY_BRAIN_MACHINE_ID="$machine_id" \
      DEVFINITY_BRAIN_AGENT_EMAIL="$agent_email" \
      DEVFINITY_BRAIN_EXPECTED_TEXT="$expected_text" \
      DEVFINITY_BRAIN_TARGET_ID="$target_brain_id" \
      node --import tsx scripts/devfinity-brain-smoke.ts "$action"
  )
}

personal_agent_brain_id() {
  container exec "$container_machine_id" fbrain brain list --json >"$brains_json"
  node - "$brains_json" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const personal = (response.brains || []).find(
  (brain) => brain.kind === "personal" && brain.role === "personal_agent"
);
if (!personal?.brainId) {
  throw new Error("Agent Principal cannot discover its user-owned Personal Brain as Personal Agent");
}
process.stdout.write(personal.brainId);
JS
}

open_and_sync_personal_brain() {
  container exec "$container_machine_id" fbrain folder create agent-notes \
    --brain "$brain_id" \
    --name "Agent notes" \
    --path agent-notes \
    --json >/dev/null
  container exec "$container_machine_id" fbrain open "$brain_id" --json >"$brain_open_json"
  node - "$brain_open_json" "$brain_tree" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (response.path !== process.argv[3]) {
  throw new Error(`fbrain opened ${response.path}, expected durable tree ${process.argv[3]}`);
}
JS
  container exec -w "$brain_tree" "$container_machine_id" fbrain sync now --json \
    >"$brain_sync_json"
  assert_personal_agent_scope
  container exec "$container_machine_id" /bin/bash -lc '
    test "$FINITE_HOME" = /data/agent
    test "$FBRAIN_CONFIG_DIR" = /data/agent/fbrain
    test "$FBRAIN_WORKING_TREE_ROOT" = /data/workspace/finitebrain
    test -f /data/agent/identity/identity.json
    test -d /data/agent/fbrain
    test ! -e /root/.finite/identity/identity.json
    test ! -e /root/.finitebrain
    test ! -e /root/finitebrain
  '
}

assert_personal_agent_scope() {
  container exec "$container_machine_id" cat \
    "$brain_tree/.finitebrain/brain-directory.json" >"$brain_directory_json"
  container exec "$container_machine_id" cat \
    "$brain_tree/.finitebrain/working-tree-state.json" >"$brain_tree_state_json"
  node - \
    "$brain_directory_json" \
    "$brain_tree_state_json" \
    "$brain_id" \
    "$agent_npub_before" <<'JS'
const fs = require("node:fs");
const directory = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const treeState = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
const expectedBrainId = process.argv[4];
const agentNpub = process.argv[5];
if (directory.brain?.id !== expectedBrainId || directory.brain?.kind !== "personal") {
  throw new Error("Agent Working Tree is not the user-owned Personal Brain");
}
if (!directory.brain.ownerNpub || directory.brain.ownerNpub === agentNpub) {
  throw new Error("Agent Working Tree must name the distinct user owner, never the Agent Principal");
}
const roots = treeState.folderRoots || [];
const notes = roots.find((root) => root.folderId === "agent-notes" && root.path === "agent-notes");
if (!notes || roots.some((root) => root.canRead !== true || root.metadataOnly !== false)) {
  throw new Error(
    `Personal Agent must read every Personal Brain Folder; unexpected roots: ${JSON.stringify(roots)}`
  );
}
JS
}

write_personal_agent_note() {
  container exec \
    -e "DEVFINITY_BRAIN_PROOF=$brain_proof" \
    -w "$brain_tree/agent-notes" \
    "$container_machine_id" \
    /bin/bash -lc '
      umask 077
      printf "# %s\n\nWritten by the paired Agent Principal through fbrain.\n" \
        "$DEVFINITY_BRAIN_PROOF" >devfinity-agent-proof.md
    '
  container exec -w "$brain_tree" "$container_machine_id" fbrain sync now --json \
    >"$brain_sync_json"
}

requesting_user_account_id() {
  node - "$chat_state_json" <<'JS'
const fs = require("node:fs");
const state = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const accountId = String(state.identity?.account_id || "");
if (!/^[0-9a-f]{64}$/u.test(accountId)) {
  throw new Error("Hosted Web Device did not expose the authenticated human account id");
}
process.stdout.write(accountId);
JS
}

publish_private_requesting_user_site() {
  local init_fields
  sites_run_id="$(date +%s)-$$"
  sites_slug="devfinity-private-${sites_run_id}"
  sites_marker="Devfinity private Sites ${sites_run_id}"
  sites_tree="/data/workspace/${sites_slug}"
  requesting_user_id="$(requesting_user_account_id)"

  container exec \
    -e "DEVFINITY_SITES_SLUG=$sites_slug" \
    -e "DEVFINITY_SITES_MARKER=$sites_marker" \
    "$container_machine_id" \
    /bin/bash -lc '
      set -euo pipefail
      tree="/data/workspace/$DEVFINITY_SITES_SLUG"
      test ! -e "$tree"
      mkdir -p "$tree/site"
      printf "%s\n" \
        "[project]" \
        "slug = \"$DEVFINITY_SITES_SLUG\"" \
        "" \
        "[outputs.site]" \
        "kind = \"site\"" \
        "site_name = \"$DEVFINITY_SITES_SLUG\"" \
        "branch = \"main\"" \
        "path = \"site\"" \
        "spa = false" >"$tree/finite.toml"
      printf "<h1>%s</h1>\n" "$DEVFINITY_SITES_MARKER" >"$tree/site/index.html"
    '

  container exec "$container_machine_id" fsite auth register --output json \
    >"$sites_auth_json"
  container exec -w "$sites_tree" "$container_machine_id" \
    fsite project init \
      --config finite.toml \
      --requesting-user-npub "$requesting_user_id" \
      --dry-run \
      --output json \
    >"$sites_dry_run_json"
  container exec -w "$sites_tree" "$container_machine_id" \
    fsite project init \
      --config finite.toml \
      --requesting-user-npub "$requesting_user_id" \
      --output json \
    >"$sites_init_json"

  init_fields="$(node - "$sites_init_json" "$sites_slug" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const expectedSlug = process.argv[3];
const output = response.outputs?.[0];
if (
  response.slug !== expectedSlug ||
  !response.requesting_user_npub?.startsWith("npub1") ||
  !output?.requesting_user_shared ||
  output.visibility !== "private" ||
  typeof output.output_id !== "string" ||
  typeof output.output_url !== "string" ||
  typeof response.git_remote_url !== "string"
) {
  throw new Error(`Project Init did not create the private requesting-user Share: ${JSON.stringify(response)}`);
}
process.stdout.write([
  output.output_id,
  output.output_url,
  response.git_remote_url,
].join("\t"));
JS
)"
  IFS=$'\t' read -r sites_output_id sites_url sites_git_remote <<<"$init_fields"

  container exec \
    -e GIT_CONFIG_GLOBAL=/data/agent/gitconfig \
    "$container_machine_id" \
    fsite auth git "$sites_slug" --store --output json \
    >"$sites_git_auth_json"
  container exec \
    -e GIT_CONFIG_GLOBAL=/data/agent/gitconfig \
    -e "DEVFINITY_SITES_GIT_REMOTE=$sites_git_remote" \
    -w "$sites_tree" \
    "$container_machine_id" \
    /bin/bash -lc '
      set -euo pipefail
      git init -b main
      git config user.name "Devfinity Sites Smoke"
      git config user.email "devfinity-sites-smoke@finite.invalid"
      git add finite.toml site
      git commit -m "Publish private requesting-user smoke site"
      git remote add finite "$DEVFINITY_SITES_GIT_REMOTE"
      git push finite main
    '

  local started status
  started="$(date +%s)"
  while true; do
    status="$(curl -sS --max-time 5 -o /dev/null -w '%{http_code}' "$sites_url" || true)"
    if [[ "$status" == "401" ]]; then
      break
    fi
    if (( "$(date +%s)" - started >= 90 )); then
      echo "Private Sites Output did not publish at $sites_url within 90s; last status $status" >&2
      return 1
    fi
    sleep 1
  done
  assert_site_unauthorized
  issue_and_redeem_site_preview "$sites_cookie_jar_before"
  echo "agent publish -> requesting user private preview ok: $sites_url"
}

issue_and_redeem_site_preview() {
  local cookie_jar="$1"
  local redeem_url status
  node -e 'process.stdout.write(JSON.stringify({ url: process.argv[1] }))' \
    "$sites_url" >"$sites_preview_request_json"
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$sites_preview_request_json" \
    "$dashboard_origin/api/site-previews/machines/$machine_id/session" \
    >"$sites_preview_response_json"
  redeem_url="$(node - "$sites_preview_response_json" "$sites_url" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const original = new URL(process.argv[3]).toString();
const redeem = new URL(String(response.url || ""));
if (
  redeem.origin !== new URL(original).origin ||
  redeem.pathname !== "/_finite/auth" ||
  !/^[0-9a-f]{64}$/u.test(redeem.searchParams.get("native_token") || "")
) {
  throw new Error(`Dashboard did not return a native Sites redemption URL: ${JSON.stringify(response)}`);
}
process.stdout.write(redeem.toString());
JS
)"
  status="$(curl -sS --max-time 15 \
    -D "$sites_redeem_headers" \
    -o /dev/null \
    -c "$cookie_jar" \
    -w '%{http_code}' \
    "$redeem_url")"
  if [[ "$status" != "303" ]]; then
    echo "Sites redemption returned HTTP $status instead of 303" >&2
    return 1
  fi
  assert_site_cookie_works "$cookie_jar"
}

assert_site_cookie_works() {
  local cookie_jar="$1"
  local body
  body="$(curl -fsS --max-time 15 -b "$cookie_jar" "$sites_url")"
  if [[ "$body" != *"$sites_marker"* ]]; then
    echo "Authenticated Sites response did not contain the smoke marker" >&2
    return 1
  fi
}

assert_site_unauthorized() {
  local status
  status="$(curl -sS --max-time 15 -o /dev/null -w '%{http_code}' "$sites_url")"
  if [[ "$status" != "401" ]]; then
    echo "Private Sites Output returned HTTP $status without a Viewer Cookie" >&2
    return 1
  fi
}

revoke_requesting_user_site() {
  container exec -w "$sites_tree" "$container_machine_id" \
    fsite project share "$sites_slug" "$sites_output_id" \
      --remove-npub "$requesting_user_id" \
      --output json \
    >"$sites_revoke_json"
  node - "$sites_revoke_json" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if ((response.shared_npubs || []).length !== 0) {
  throw new Error(`Requesting-user Share was not revoked: ${JSON.stringify(response)}`);
}
JS

  local status
  for cookie_jar in "$sites_cookie_jar_before" "$sites_cookie_jar_after"; do
    status="$(curl -sS --max-time 15 -o /dev/null -b "$cookie_jar" -w '%{http_code}' "$sites_url")"
    if [[ "$status" != "401" ]]; then
      echo "Revoked Sites Viewer Cookie returned HTTP $status instead of 401" >&2
      return 1
    fi
  done
  assert_site_unauthorized

  node -e 'process.stdout.write(JSON.stringify({ url: process.argv[1] }))' \
    "$sites_url" >"$sites_preview_request_json"
  curl -fsS --max-time 30 \
    -H 'content-type: application/json' \
    --data-binary "@$sites_preview_request_json" \
    "$dashboard_origin/api/site-previews/machines/$machine_id/session" \
    >"$sites_preview_response_json"
  node - "$sites_preview_response_json" "$sites_url" <<'JS'
const fs = require("node:fs");
const response = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (new URL(String(response.url || "")).toString() !== new URL(process.argv[3]).toString()) {
  throw new Error(`Dashboard unexpectedly minted a Sites viewer session after revocation: ${JSON.stringify(response)}`);
}
JS
  echo "requesting-user Share revocation invalidated live and future Sites sessions"
}

