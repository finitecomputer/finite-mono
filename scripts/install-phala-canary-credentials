#!/usr/bin/env bash
set -euo pipefail

host="${1:-root@64.34.82.77}"
if [[ "$#" -gt 1 ]]; then
  printf 'usage: %s [root@finite-lat-1]\n' "$0" >&2
  exit 2
fi

read -r -s -p 'Phala Cloud API key (input is hidden): ' phala_api_key
printf '\n'
trap 'unset phala_api_key' EXIT
if [[ -z "$phala_api_key" || "$phala_api_key" == *$'\n'* ]]; then
  printf 'Phala Cloud API key must be one non-empty line\n' >&2
  exit 1
fi

remote_hostname="$(ssh -o BatchMode=yes "$host" hostname)"
if [[ "$remote_hostname" != "finite-lat-1" ]]; then
  printf 'refusing credential install on unexpected host %q\n' "$remote_hostname" >&2
  exit 1
fi

current_metadata="$(
  ssh -o BatchMode=yes "$host" \
    "sed -n 's/^FC_CORE_RUNNER_CREDENTIALS_JSON=//p' /etc/finite/core.env"
)"
if [[ -z "$current_metadata" ]]; then
  printf 'Core runner credential metadata is missing\n' >&2
  exit 1
fi

new_metadata="$(
  jq -ce '
    if any(.[]; .credentialId == "finite-phala-runner-1"
      or .runnerId == "finite-phala-runner-1"
      or .tokenEnv == "FC_CORE_RUNNER_CREDENTIAL_TOKEN_PHALA_CURRENT")
    then error("Phala runner credential already exists")
    else . + [{
      credentialId: "finite-phala-runner-1",
      tokenEnv: "FC_CORE_RUNNER_CREDENTIAL_TOKEN_PHALA_CURRENT",
      runnerId: "finite-phala-runner-1",
      runnerClasses: ["phala"],
      sourceHostId: "finite-lat-1-phala-control-1"
    }]
    end
  ' <<<"$current_metadata"
)"

old_metadata_b64="$(printf '%s' "$current_metadata" | base64 | tr -d '\n')"
new_metadata_b64="$(printf '%s' "$new_metadata" | base64 | tr -d '\n')"
phala_api_key_b64="$(printf '%s' "$phala_api_key" | base64 | tr -d '\n')"
unset phala_api_key current_metadata new_metadata

ssh -o BatchMode=yes "$host" /bin/sh -s <<REMOTE
set -eu
umask 077

old_metadata=\$(printf '%s' '$old_metadata_b64' | base64 -d)
new_metadata=\$(printf '%s' '$new_metadata_b64' | base64 -d)
phala_api_key=\$(printf '%s' '$phala_api_key_b64' | base64 -d)
test -n "\$old_metadata"
test -n "\$new_metadata"
test -n "\$phala_api_key"
test "\$(hostname)" = finite-lat-1

current_metadata=\$(sed -n 's/^FC_CORE_RUNNER_CREDENTIALS_JSON=//p' /etc/finite/core.env)
test "\$current_metadata" = "\$old_metadata"
test "\$(sed -n '/^FC_CORE_RUNNER_CREDENTIAL_TOKEN_PHALA_CURRENT=/p' /etc/finite/core.env | wc -l)" -eq 0
test "\$(sed -n '/^FC_RUNNER_FINITE_PRIVATE_SPECIALIZATION_WORKER_API_KEY=./p' /etc/finite/runner.env | wc -l)" -eq 1

core_tmp=\$(mktemp /etc/finite/core.env.phala.XXXXXX)
phala_tmp=\$(mktemp /etc/finite/phala-runner.env.XXXXXX)
cleanup() {
  rm -f "\$core_tmp" "\$phala_tmp"
  unset phala_api_key runner_token
}
trap cleanup EXIT HUP INT TERM

runner_token=\$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')
test "\${#runner_token}" -eq 64

awk '
  !/^FC_CORE_RUNNER_CREDENTIALS_JSON=/ &&
  !/^FC_CORE_RUNNER_CREDENTIAL_TOKEN_PHALA_CURRENT=/
' /etc/finite/core.env >"\$core_tmp"
printf 'FC_CORE_RUNNER_CREDENTIALS_JSON=%s\n' "\$new_metadata" >>"\$core_tmp"
printf 'FC_CORE_RUNNER_CREDENTIAL_TOKEN_PHALA_CURRENT=%s\n' "\$runner_token" >>"\$core_tmp"

printf 'FC_CORE_RUNNER_API_TOKEN=%s\n' "\$runner_token" >"\$phala_tmp"
printf 'FC_RUNNER_PHALA_API_KEY=%s\n' "\$phala_api_key" >>"\$phala_tmp"
sed -n '/^FC_RUNNER_FINITE_PRIVATE_SPECIALIZATION_WORKER_API_KEY=./p' \
  /etc/finite/runner.env >>"\$phala_tmp"

timestamp=\$(date -u +%Y%m%dT%H%M%SZ)
backup=/etc/finite/core.env.pre-phala-canary-\$timestamp
install -o root -g root -m 0600 /etc/finite/core.env "\$backup"
install -o root -g root -m 0600 "\$phala_tmp" /etc/finite/phala-runner.env
install -o root -g root -m 0600 "\$core_tmp" /etc/finite/core.env

if ! systemctl restart finite-saas-core.service ||
   ! systemctl is-active --quiet finite-saas-core.service; then
  install -o root -g root -m 0600 "\$backup" /etc/finite/core.env
  systemctl restart finite-saas-core.service
  rm -f /etc/finite/phala-runner.env
  printf 'Core rejected the credential keyring; original config restored\n' >&2
  exit 1
fi

test "\$(stat -c '%U:%G %a' /etc/finite/phala-runner.env)" = 'root:root 600'
printf 'Installed the distinct Phala/Core credentials; Core is active. Backup: %s\n' "\$backup"
REMOTE

unset old_metadata_b64 new_metadata_b64 phala_api_key_b64
