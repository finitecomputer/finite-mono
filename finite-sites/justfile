set shell := ["../scripts/dev-shell", "-cu"]

sites_packages := "-p finitesites-proto -p finitesites-blob -p finitesites-store -p finitesites-engine -p finitesitesd -p fsite-cli"

default: test

build:
    cargo build {{sites_packages}}

test:
    cargo test {{sites_packages}}

lint:
    cargo fmt {{sites_packages}} -- --check
    cargo clippy {{sites_packages}} --all-targets -- -D warnings

fmt:
    cargo fmt {{sites_packages}}

# Run the dev server against .dev-data (registry, blobs, outbox, secret).
dev:
    cargo run -p finitesitesd -- serve --data .dev-data

# Add an operator publish grant on the dev server's data dir.
allow npub note="dev":
    cargo run -p finitesitesd -- allow --data .dev-data {{npub}} --note "{{note}}"

allowed:
    cargo run -p finitesitesd -- allowed --data .dev-data

# Wipe local dev state.
clean-dev:
    rm -rf .dev-data
