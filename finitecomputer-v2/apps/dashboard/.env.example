# Copy this file to apps/dashboard/.env.local for local development.
# Never commit real secrets or sandbox keys.

# Public dashboard URL. Stripe Checkout and Billing Portal return here.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Core API. FC_CORE_API_TOKEN must match the service token configured on Core.
FC_CORE_BASE_URL=http://127.0.0.1:4200
FC_CORE_API_TOKEN=replace-with-local-core-service-token

# WorkOS AuthKit. WORKOS_COOKIE_PASSWORD must be at least 32 characters.
FC_WORKOS_AUTH_ENABLED=1
WORKOS_API_KEY=workos_api_key_replace_me
WORKOS_CLIENT_ID=client_replace_me
WORKOS_COOKIE_PASSWORD=replace-with-at-least-32-characters
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Local-only account-auth bypass for browser tests and local canaries.
# Do not enable this in deployed environments.
FC_DASHBOARD_ALLOW_DEV_ACCOUNT_AUTH=1
FC_DASHBOARD_DEV_EMAIL=dev@finite.vip
FC_DASHBOARD_DEV_WORKOS_USER_ID=user_dev_local

# Stripe Billing v0.
# STRIPE_SECRET_KEY is a Stripe test or live secret key.
STRIPE_SECRET_KEY=stripe_secret_key_replace_me

# Create a recurring Stripe Price for the standard hosted agent plan and put
# its price_... id here. Stripe owns amount, interval, coupons, and promo codes.
STRIPE_FINITE_COMPUTER_STANDARD_PRICE_ID=price_replace_me

# Use the Stripe CLI locally or the Dashboard webhook endpoint in Stripe to get
# the whsec_... signing secret for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional for future client-side Stripe UI. The current Checkout flow is a
# server-side redirect and does not read this variable.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=stripe_publishable_key_replace_me
