# Copy to deploy/finite-chat/lat1/secrets/workspace.env.
# Operator-created; deploys never write this file.

# SSH target for the current lat1/Core host that fronts chat.finite.computer.
HOST_SSH_HOST=replace-with-hostname-or-ip
HOST_SSH_USER=root
HOST_SSH_PORT=22

# Optional overrides for the remote service.
# FINITECHAT_BIND_ADDR=10.42.0.1:8787
# FINITECHAT_SYSTEMD_UNIT_DIR=/run/systemd/system
