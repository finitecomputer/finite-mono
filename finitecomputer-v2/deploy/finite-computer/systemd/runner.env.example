FC_CORE_URL=http://10.43.237.180:4200
FC_CORE_API_TOKEN=replace-with-core-service-token
FC_RUNNER_ID=finite-computer-runner-1
FC_RUNNER_SOURCE_HOST_ID=finite-computer-1
FC_RUNNER_BACKEND=phala
FC_RUNNER_RUNTIME_ARTIFACT_ID=finite-agent-runtime-canary-20260702-41b0c6d
# Finite Private defaults. Both are optional overrides: the runner defaults to
# these exact values (DEFAULT_FINITE_PRIVATE_BASE_URL / DEFAULT_FINITE_PRIVATE_MODEL
# in finite-saas-runner) and passes them to each runtime as
# FINITE_PRIVATE_BASE_URL/FINITE_PRIVATE_MODEL and FINITECHAT_HERMES_BASE_URL/
# FINITECHAT_HERMES_MODEL. The base URL domain keeps the historical kimi-k2-6
# name but the deployed limiter now serves glm-5-2.
FC_RUNNER_FINITE_PRIVATE_BASE_URL=https://kimi-k2-6.finite.containers.tinfoil.dev/v1
FC_RUNNER_FINITE_PRIVATE_MODEL=glm-5-2

# Phala is the first-class SaaS confidential runner. Keep the API key in this
# host-only env file; the runner passes it to the Phala CLI through process env,
# not argv, and writes per-runtime Finite Private keys only into the env file
# sealed by `phala deploy`.
PHALA_CLOUD_API_KEY=replace-with-phala-api-key
FC_RUNNER_PHALA_BIN=/usr/local/bin/phala
FC_RUNNER_PHALA_INSTANCE_TYPE=tdx.small
FC_RUNNER_PHALA_DISK_SIZE=40G
FC_RUNNER_PHALA_KMS=phala
FC_RUNNER_PHALA_PUBLIC_LOGS=false
FC_RUNNER_PHALA_PUBLIC_SYSINFO=false
# Optional placement override.
# FC_RUNNER_PHALA_REGION=us-west

FC_RUNNER_WORK_ROOT=/var/lib/finite/saas-runner

# Product launches fetch the promoted artifact kind, reference, and state schema
# from Core using FC_RUNNER_RUNTIME_ARTIFACT_ID. Docker is the local/remote test
# backend; Phala is the first-class confidential runtime backend.
# Set FC_RUNNER_DRAIN=true before maintenance to stop this host from taking new
# Core leases while other runner hosts continue.
FC_RUNNER_DRAIN=false
# Bound one-shot leasing on small hosts.
# FC_RUNNER_MAX_SANDBOXES=4
FC_RUNNER_RUNTIME_READY_TIMEOUT_SECS=120
FC_RUNNER_RUNTIME_READY_INTERVAL_MS=2000
# Phala deploys can include CVM allocation, image pull, compose startup, and
# runtime readiness checks.
FC_RUNNER_LAUNCH_TIMEOUT_SECS=900
# Applies to short operational commands such as docker stop/restart or
# phala cvms stop/restart/delete.
FC_RUNNER_COMMAND_TIMEOUT_SECS=15
