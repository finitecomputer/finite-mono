set shell := ["../scripts/dev-shell", "-cu"]

# Lists just commands
default:
    just --list-submodules --list

# Starts devfinity harness. `just dev up` or `just dev up --headless`
up *args:
    cd .. && cargo run -p devfinity -- up {{ args }}

# Starts an isolated, fresh services-only stack, runs its smoke test, and tears it down.
# This portable profile is the Linux CI gate; it does not claim to launch an Agent Runtime.
smoke:
    cd .. && cargo run -p devfinity -- --state-dir .local-state/dfs up --services-only --fresh --headless -- scripts/devfinity-smoke

# Starts the real Apple Container SaaS stack and proves dashboard -> Core -> Runner -> Runtime.
saas-smoke:
    cd .. && cargo run -p devfinity -- up --headless -- scripts/devfinity-saas-smoke

# Starts the headless stack, runs the ignored Rust smoke test, and tears the stack down
rust-smoke:
    cd .. && cargo run -p devfinity -- --state-dir .local-state/dfs up --services-only --fresh --headless -- cargo test -p devfinity --locked --test stack_smoke -- --ignored --nocapture

# Prints running devfinity infra status
status:
    cd .. && cargo run -p devfinity -- status

# Kills running devfinity processes
cleanup:
    cd .. && cargo run -p devfinity -- cleanup
