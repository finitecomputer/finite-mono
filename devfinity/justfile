set shell := ["../scripts/dev-shell", "-cu"]

# Lists just commands
default:
    just --list-submodules --list

# Starts devfinity harness. `just dev up` or `just dev up --headless`
up *args:
    cd .. && cargo run -p devfinity -- up {{ args }}

# Starts the headless backend stack, runs the backend smoke test, and tears it down
smoke:
    cd .. && cargo run -p devfinity -- up --headless -- scripts/devfinity-smoke

# Runs the ignored Rust backend smoke test through the devfinity fixture API
rust-smoke:
    cd .. && cargo test -p devfinity --locked --test stack_smoke -- --ignored --nocapture

# Prints running devfinity infra status
status:
    cd .. && cargo run -p devfinity -- status

# Kills running devfinity processes
cleanup:
    cd .. && cargo run -p devfinity -- cleanup
