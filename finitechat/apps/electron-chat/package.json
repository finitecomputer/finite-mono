{
  "name": "finitechat-electron",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "FINITECHAT_DASHBOARD_URL=http://127.0.0.1:3000 FINITECHAT_DAEMON_BINARY=target/debug/finitechatd electron .",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --test electron/*.test.cjs",
    "check": "npm run test && npm run typecheck && npm run build",
    "electron": "FINITECHAT_DAEMON_BINARY=target/debug/finitechatd electron .",
    "play": "npm run build && npm run electron",
    "package:mac-alpha": "npm run build && node scripts/package-macos-alpha.mjs"
  },
  "dependencies": {
    "@finite/chat-ui": "file:../../packages/finitechat-chat-ui",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^38.0.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.0.0",
    "vaul": "^1.1.2",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.60.0"
  }
}
