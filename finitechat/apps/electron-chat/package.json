{
  "name": "finitechat-electron",
  "version": "0.1.7",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npm run dev:electron",
    "dev:electron": "FINITECHAT_DASHBOARD_URL=http://127.0.0.1:13002 FINITECHAT_DAEMON_BINARY=target/debug/finitechatd electron .",
    "dev:electron:fixture": "node scripts/run-electron-web-design-fixture.mjs",
