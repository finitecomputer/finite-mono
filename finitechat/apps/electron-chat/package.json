    "package:mac": "node scripts/package-macos-alpha.mjs",
    "package:mac-alpha": "npm run package:mac"
  },
  "dependencies": {
    "electron": "42.2.0"
  },
  "devDependencies": {
    "@electron/osx-sign": "^2.4.0"
  }
